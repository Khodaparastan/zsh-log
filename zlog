###
# Get system hostname (cached for performance)
# Usage:
#   __z::sys::hostname
#   local hostname="$REPLY"
#
# Output: Sets REPLY variable with hostname
# Returns: 0 always (uses "unknown" as fallback)
#
# Performance: O(1) after first call (cached)
# Fallback chain: HOST → HOSTNAME → hostname(1) → /etc/hostname → /proc/sys/kernel/hostname
###
__z::sys::hostname() {
  emulate -L zsh
  setopt localoptions extended_glob no_unset

  # Return cached value if available
  if [[ -n "$_zlog_sys_cache[hostname]" ]]; then
    REPLY="${_zlog_sys_cache[hostname]}"
    return 0
  fi

  local hostname=""

  # Try multiple sources in order of preference
  # 1. Try HOST variable (most common in zsh)
  if [[ -n "${HOST-}" ]]; then
    hostname="$HOST"
  # 2. Try HOSTNAME variable (bash compatibility)
  elif [[ -n "${HOSTNAME-}" ]]; then
    hostname="$HOSTNAME"
  # 3. Try hostname command
  elif command -v hostname &>/dev/null; then
    hostname=$(hostname 2>/dev/null) || hostname=""
  # 4. Try reading /etc/hostname (Linux, some BSDs)
  elif [[ -r /etc/hostname ]]; then
    hostname=$(< /etc/hostname 2>/dev/null) || hostname=""
  # 5. Try reading /proc/sys/kernel/hostname (Linux)
  elif [[ -r /proc/sys/kernel/hostname ]]; then
    hostname=$(< /proc/sys/kernel/hostname 2>/dev/null) || hostname=""
  fi

  # Trim whitespace (leading and trailing)
  hostname="${hostname##[[:space:]]##}"
  hostname="${hostname%%[[:space:]]##}"

  # Use default if empty
  hostname="${hostname:-unknown}"

  # Cache and return
  _zlog_sys_cache[hostname]="$hostname"
  REPLY="$hostname"

  __z::log::debug_internal "Hostname cached: $hostname"
  return 0
}

###
# Get current process ID
# Usage:
#   __z::sys::pid
#   local pid="$REPLY"
#
# Output: Sets REPLY variable with PID
# Returns: 0 always
#
# Performance: O(1) - returns cached value
###
__z::sys::pid() {
  emulate -L zsh
  setopt localoptions no_unset

  REPLY="$_zlog_sys_cache[pid]"
  return 0
}

###
# Get username (cached for performance)
# Usage:
#   __z::sys::username
#   local user="$REPLY"
#
# Output: Sets REPLY variable with username
# Returns: 0 always (uses "unknown" as fallback)
#
# Performance: O(1) after first call (cached)
# Fallback chain: USER → USERNAME → LOGNAME → whoami(1) → id(1)
###
__z::sys::username() {
  emulate -L zsh
  setopt localoptions extended_glob no_unset

  # Return cached value if available
  if [[ -n "$_zlog_sys_cache[username]" ]]; then
    REPLY="${_zlog_sys_cache[username]}"
    return 0
  fi

  local username=""

  # Try multiple sources in order of preference
  # 1. Try USER variable (most common)
  if [[ -n "${USER-}" ]]; then
    username="$USER"
  # 2. Try USERNAME variable (Windows/Cygwin compatibility)
  elif [[ -n "${USERNAME-}" ]]; then
    username="$USERNAME"
  # 3. Try LOGNAME variable (POSIX standard)
  elif [[ -n "${LOGNAME-}" ]]; then
    username="$LOGNAME"
  # 4. Try whoami command
  elif command -v whoami &>/dev/null; then
    username=$(whoami 2>/dev/null) || username=""
  # 5. Try id command (POSIX fallback)
  elif command -v id &>/dev/null; then
    username=$(id -un 2>/dev/null) || username=""
  fi

  # Trim whitespace
  username="${username##[[:space:]]##}"
  username="${username%%[[:space:]]##}"

  # Use default if empty
  username="${username:-unknown}"

  # Cache and return
  _zlog_sys_cache[username]="$username"
  REPLY="$username"

  __z::log::debug_internal "Username cached: $username"
  return 0
}

###
# Clear system information cache
# Useful after user switch, hostname change, container migration, etc.
#
# Usage: z::log::clear_sys_cache [type]
#
# Arguments:
#   type - Optional: "hostname", "username", "pid", or "all" (default: all)
#
# Returns: 0 on success, 1 on invalid type
###
z::log::clear_sys_cache() {
  emulate -L zsh
  setopt localoptions no_unset

  local type="${1:-all}"

  case "$type" in
    hostname)
      _zlog_sys_cache[hostname]=""
      __z::log::debug_internal "Hostname cache cleared"
      ;;
    username)
      _zlog_sys_cache[username]=""
      __z::log::debug_internal "Username cache cleared"
      ;;
    pid)
      # Update PID (useful after fork/exec)
      _zlog_sys_cache[pid]="$$"
      __z::log::debug_internal "PID cache updated to: $$"
      ;;
    all)
      _zlog_sys_cache[hostname]=""
      _zlog_sys_cache[username]=""
      _zlog_sys_cache[pid]="$$"
      __z::log::debug_internal "All system caches cleared"
      ;;
    *)
      print -r -u2 -- "zlog: Invalid cache type: $type (use: hostname, username, pid, all)"
      return 1
      ;;
  esac

  return 0
}

###
# Get all system information at once (for efficiency)
# Usage:
#   __z::sys::get_all_info
#   local hostname="${REPLY[hostname]}"
#   local username="${REPLY[username]}"
#   local pid="${REPLY[pid]}"
#
# Output: Sets reply as key/value pairs: hostname value username value pid value
# Returns: 0 always
#
# Note: This is more efficient than calling each function separately
#       when you need all three values
###
__z::sys::get_all_info() {
  emulate -L zsh
  setopt localoptions no_unset

  # Get each piece of info (uses cache if available)
  __z::sys::hostname
  local hostname="$REPLY"

  __z::sys::username
  local username="$REPLY"

  __z::sys::pid
  local pid="$REPLY"

  reply=(hostname "$hostname" username "$username" pid "$pid")

  return 0
}

