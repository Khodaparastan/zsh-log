###
# Internal helper to check if a log level is active
# Returns 0 (true) if the level will be logged to console or file
###
__z::log::is_level_active() {
  emulate -L zsh

  local check_level="$1"
  local console_level="${_zlog_config[level]:-2}"
  local file_level="${_zlog_config[file_level]:--1}"

  # If file level is -1, follow console level
  (( file_level == -1 )) && file_level=$console_level

  # Return 0 (true) if either console or an enabled file target will log this level
  (( check_level <= console_level || ( _zlog_state[file_enabled] && check_level <= file_level ) ))
}

###
# Check if error level is active
# Returns 0 (true) if error messages will be logged
