###############################################################################
# UTILITY FUNCTIONS - JSON ESCAPING
###############################################################################

__z::json::escape() {
  emulate -L zsh
  setopt localoptions extended_glob no_unset

  local input="${1-}"

  # Fast path
  if [[ "$input" != *[\\\"$'\n\r\t\b\f\x00-\x1f\x7f']* ]]; then
    REPLY="$input"
    return 0
  fi

  # Slow path
  REPLY="$input"
  REPLY="${REPLY//\\/\\\\}"
  REPLY="${REPLY//\"/\\\"}"
  REPLY="${REPLY//$'\n'/\\n}"
  REPLY="${REPLY//$'\r'/\\r}"
  REPLY="${REPLY//$'\t'/\\t}"
  REPLY="${REPLY//$'\b'/\\b}"
  REPLY="${REPLY//$'\f'/\\f}"

  if [[ "$REPLY" == *[$'\x00-\x1f\x7f']* ]]; then
    __z::json::escape_control_chars "$REPLY"
  fi

  return 0
}

__z::json::escape_control_chars() {
  emulate -L zsh
  setopt localoptions no_unset

  local input="$1"
  local output=""
  local char hex
  local i

  for (( i = 1; i <= ${#input}; i++ )); do
    char="${input[i]}"

    case "$char" in
      $'\n'|$'\r'|$'\t'|$'\b'|$'\f'|'\\'|'"')
        output+="$char"
        ;;
      [$'\x00-\x1f\x7f'])
        printf -v hex '%04x' "'$char"
        output+="\\u${hex}"
        ;;
      *)
        output+="$char"
        ;;
    esac
  done

  REPLY="$output"
  return 0
}

__z::json::validate() {
  emulate -L zsh
  setopt localoptions no_unset

  (( ${_zlog_config[debug_mode]:-0} )) || return 0

  local json="$1"
  local cleaned="${json//\\\"/}"

  if [[ "$cleaned" == *\"* ]]; then
    __z::log::debug_internal "JSON validation failed: unescaped quote found"
    return 1
  fi

  if [[ "$json" == *\\ ]]; then
    __z::log::debug_internal "JSON validation failed: trailing backslash"
    return 1
  fi

  return 0
}


