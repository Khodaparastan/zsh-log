###
# Trim whitespace from string
# Usage: __z::str::trim "  text  "
#        local trimmed="$REPLY"
#
# Output: Sets REPLY variable with trimmed string
# Returns: 0 always
#
# Performance: O(n) where n is string length
# Removes: Leading and trailing whitespace (spaces, tabs, newlines, etc.)
###
__z::str::trim() {
  emulate -L zsh
  setopt localoptions extended_glob no_unset

  local input="${1-}"

  # Remove leading and trailing whitespace using extended_glob
  REPLY="${input##[[:space:]]##}"
  REPLY="${REPLY%%[[:space:]]##}"

  return 0
}

###
# Check if string is empty or only whitespace
# Usage: if __z::str::is_empty "  "; then ...; fi
#
# Arguments:
#   input - String to check
#
# Returns: 0 if blank (empty or only whitespace), 1 if not blank
#
# Performance: O(n) worst case, O(1) for empty strings
###
__z::str::is_empty() {
  emulate -L zsh
  setopt localoptions extended_glob no_unset

  local input="${1-}"

  # Check if empty or only whitespace
  [[ -z "$input" || "$input" == [[:space:]]## ]]
}

###
# Truncate string to maximum length
# Usage: __z::str::truncate "long text" 10 "..."
#        local truncated="$REPLY"
#
# Arguments:
#   text - Input string
#   max_length - Maximum length (including suffix)
#   suffix - Optional suffix to add (default: "...")
#
# Output: Sets REPLY variable with truncated string
# Returns: 0 on success, 1 on invalid max_length
#
# Performance: O(1) - uses zsh substring slicing
###
__z::str::truncate() {
  emulate -L zsh
  setopt localoptions no_unset

  local text="${1-}"
  local max_length="${2-}"
  local suffix="${3:-...}"

  # Validate max_length is a positive integer
  if [[ ! "$max_length" =~ '^[0-9]+$' ]] || (( max_length < 1 )); then
    REPLY="$text"
    return 1
  fi

  # No truncation needed
  if (( ${#text} <= max_length )); then
    REPLY="$text"
    return 0
  fi

  # Calculate truncation point
  local truncate_at=$(( max_length - ${#suffix} ))

  # Ensure we don't go negative
  if (( truncate_at <= 0 )); then
    # If suffix is longer than max_length, just truncate to max_length
    REPLY="${text[1,$max_length]}"
  else
    REPLY="${text[1,$truncate_at]}${suffix}"
  fi

  return 0
}

###
# Repeat string N times
# Usage: __z::str::repeat "=" 50
#        local line="$REPLY"
#
# Arguments:
#   text - String to repeat
#   count - Number of repetitions
#
# Output: Sets REPLY variable with repeated string
# Returns: 0 on success, 1 on invalid count
#
# Performance: O(n) where n is count
# Uses printf for efficiency (no loops)
###
__z::str::repeat() {
  emulate -L zsh
  setopt localoptions no_unset

  local text="${1-}"
  local count="${2-}"

  # Validate count is a non-negative integer
  if [[ ! "$count" =~ '^[0-9]+$' ]]; then
    REPLY=""
    return 1
  fi

  # Empty result for zero count
  if (( count == 0 )); then
    REPLY=""
    return 0
  fi

  # Special case: single character optimization
  if (( ${#text} == 1 )); then
    # Use printf with width specifier (very fast)
    printf -v REPLY "%${count}s" ""
    REPLY="${REPLY// /$text}"
    return 0
  fi

  # Multi-character: build using array join (faster than loop)
  local -a parts
  local i
  for (( i = 0; i < count; i++ )); do
    parts+=("$text")
  done

  # Join without separator
  local IFS=""
  REPLY="${parts[*]}"

  return 0
}

###
# Pad string to specified width
# Usage: __z::str::pad "text" 10 "left" " "
#        local padded="$REPLY"
#
# Arguments:
#   text - Input string
#   width - Desired width
#   align - "left", "right", or "center" (default: left)
#   pad_char - Character to pad with (default: space)
#
# Output: Sets REPLY variable with padded string
# Returns: 0 on success, 1 on invalid arguments
###
__z::str::pad() {
  emulate -L zsh
  setopt localoptions no_unset

  local text="${1-}"
  local width="${2-}"
  local align="${3:-left}"
  local pad_char="${4:- }"

  # Validate width
  if [[ ! "$width" =~ '^[0-9]+$' ]] || (( width < 0 )); then
    REPLY="$text"
    return 1
  fi

  # No padding needed
  if (( ${#text} >= width )); then
    REPLY="$text"
    return 0
  fi

  local pad_length=$(( width - ${#text} ))

  # Generate padding
  __z::str::repeat "$pad_char" "$pad_length"
  local padding="$REPLY"

  case "$align" in
    left)
      REPLY="${text}${padding}"
      ;;
    right)
      REPLY="${padding}${text}"
      ;;
    center)
      local left_pad=$(( pad_length / 2 ))
      local right_pad=$(( pad_length - left_pad ))
      __z::str::repeat "$pad_char" "$left_pad"
      local left="$REPLY"
      __z::str::repeat "$pad_char" "$right_pad"
      local right="$REPLY"
      REPLY="${left}${text}${right}"
      ;;
    *)
      print -r -u2 -- "zlog: Invalid alignment: $align (use: left, right, center)"
      REPLY="$text"
      return 1
      ;;
  esac

  return 0
}

###############################################################################
# MESSAGE SIZE MANAGEMENT
###############################################################################

###
# Parse human-readable size to bytes
# Usage: __z::log::parse_size "10MB"
#        local bytes="$REPLY"
#
# Supports:
#   - Pure numbers: "1024" → 1024 bytes
#   - Binary units: B, KB, MB, GB, TB (1024-based)
#   - Shorthand: K, M, G, T
#   - Decimals: "1.5MB" → 1572864 bytes
#
# Output: Sets REPLY variable with size in bytes
# Returns: 0 on success, 1 on invalid input
#
# Examples:
#   "1024" → 1024
#   "10KB" → 10240
#   "1.5MB" → 1572864
#   "2G" → 2147483648
###
__z::log::parse_size() {
  emulate -L zsh
  setopt localoptions extended_glob no_unset

  local input="${1-}"

  # Remove whitespace
  input="${input//[[:space:]]/}"

  # Convert to uppercase for easier matching
  input="${input:u}"

  # If it's just a number, assume bytes
  if [[ "$input" =~ '^[0-9]+$' ]]; then
    REPLY="$input"
    return 0
  fi

  # Parse number and unit
  # Match: decimal number followed by optional unit
  if [[ "$input" =~ '^([0-9]+\.?[0-9]*)(B|KB?|MB?|GB?|TB?)?$' ]]; then
    local number="${match[1]}"
    local unit="${match[2]:-B}"

    # Normalize unit (K → KB, M → MB, etc.)
    case "$unit" in
      K) unit="KB" ;;
      M) unit="MB" ;;
      G) unit="GB" ;;
      T) unit="TB" ;;
    esac

    # Get multiplier
    local multiplier=1
    case "$unit" in
      B)  multiplier=1 ;;
      KB) multiplier=1024 ;;
      MB) multiplier=$((1024 * 1024)) ;;
      GB) multiplier=$((1024 * 1024 * 1024)) ;;
      TB) multiplier=1099511627776 ;;  # 1024^4
      *)
        __z::log::debug_internal "Invalid size unit: $unit"
        return 1
        ;;
    esac

    # Calculate bytes (handle decimals)
    if [[ "$number" == *.* ]]; then
      local int_part="${number%%.*}"
      local frac_part="${number#*.}"

      # Calculate integer bytes
      local int_bytes=$((int_part * multiplier))

      # Pad fractional part to 6 digits for precision
      while (( ${#frac_part} < 6 )); do
        frac_part="${frac_part}0"
      done
      frac_part="${frac_part:0:6}"

      # Calculate fractional bytes
      local frac_bytes=$(( (frac_part * multiplier) / 1000000 ))

      REPLY=$((int_bytes + frac_bytes))
    else
      REPLY=$((number * multiplier))
    fi

    return 0
  fi

  __z::log::debug_internal "Invalid size format: $input"
  return 1
}

###
# Format bytes to human-readable size
# Usage: __z::log::format_size 1048576
#        local size="$REPLY"  # "1.00 MB"
#
# Output: Sets REPLY variable with formatted size
# Returns: 0 on success, 1 on invalid input
#
# Format: Uses 2 decimal places for KB/MB/GB/TB, none for bytes
# Examples:
#   0 → "0 B"
#   1024 → "1.00 KB"
#   1048576 → "1.00 MB"
#   1572864 → "1.50 MB"
###
__z::log::format_size() {
  emulate -L zsh
  setopt localoptions no_unset

  local bytes="${1-}"

  # Validate input is a non-negative integer
  if [[ ! "$bytes" =~ '^[0-9]+$' ]]; then
    REPLY="0 B"
    return 1
  fi

  # Handle zero
  if (( bytes == 0 )); then
    REPLY="0 B"
    return 0
  fi

  # Determine appropriate unit
  local -a units=(B KB MB GB TB)
  local unit_index=0
  local size=$bytes
  local divisor=1

  # Find the right unit
  while (( size >= 1024 && unit_index < ${#units} - 1 )); do
    size=$((size / 1024))
    divisor=$((divisor * 1024))
    unit_index=$((unit_index + 1))
  done

  # Format with appropriate precision
  if (( unit_index == 0 )); then
    # Bytes - no decimal
    REPLY="${bytes} B"
  else
    # Calculate precise value with 2 decimal places
    local int_part=$((bytes / divisor))
    local remainder=$((bytes % divisor))
    local decimal=$((remainder * 100 / divisor))

    # Format with 2 decimal places
    if (( decimal < 10 )); then
      REPLY="${int_part}.0${decimal} ${units[unit_index+1]}"
    else
      REPLY="${int_part}.${decimal} ${units[unit_index+1]}"
    fi
  fi

  return 0
}

###
# Set maximum message size
# Usage: z::log::set_max_message_size <size>
#
# Arguments:
#   size - Maximum message size (0 = unlimited)
#          Accepts: bytes (e.g., "1024") or human-readable (e.g., "10MB", "1.5GB")
#
# Returns: 0 on success, 1 on invalid input
#
# Examples:
#   z::log::set_max_message_size 0          # Unlimited
#   z::log::set_max_message_size 1024       # 1024 bytes
#   z::log::set_max_message_size "10KB"     # 10 kilobytes
#   z::log::set_max_message_size "1.5MB"    # 1.5 megabytes
###
z::log::set_max_message_size() {
  emulate -L zsh
  setopt localoptions no_unset

  local size_input="${1-}"

  # Validate input
  if [[ -z "$size_input" ]]; then
    print -r -u2 -- "zlog: Message size cannot be empty"
    return 1
  fi

  # Parse size
  __z::log::parse_size "$size_input"
  local parse_status=$?
  local size_bytes="$REPLY"

  if (( parse_status != 0 )); then
    print -r -u2 -- "zlog: Invalid message size: $size_input"
    print -r -u2 -- "      Use: bytes (e.g., 1024) or human-readable (e.g., 10KB, 1.5MB)"
    return 1
  fi

  # Validate non-negative
  if (( size_bytes < 0 )); then
    print -r -u2 -- "zlog: Message size cannot be negative: $size_bytes"
    return 1
  fi

  _zlog_config[max_message_size]=$size_bytes

  # Format for debug output
  if (( size_bytes == 0 )); then
    __z::log::debug_internal "Max message size set to: unlimited"
  else
    __z::log::format_size "$size_bytes"
    __z::log::debug_internal "Max message size set to: $size_bytes bytes ($REPLY)"
  fi

  return 0
}

###
# Get current max message size (human-readable)
# Usage: size=$(z::log::get_max_message_size)
# Output: Prints formatted size to stdout
###
z::log::get_max_message_size() {
  emulate -L zsh
  setopt localoptions no_unset

  local size="${_zlog_config[max_message_size]:-0}"

  if (( size == 0 )); then
    print -r -- "unlimited"
  else
    __z::log::format_size "$size"
    print -r -- "$REPLY"
  fi

  return 0
}

###
# Set truncation marker
# Usage: z::log::set_truncate_marker " [...]"
#
# Arguments:
#   marker - String to append when message is truncated
#
# Returns: 0 on success, 1 if marker is empty
###
z::log::set_truncate_marker() {
  emulate -L zsh
  setopt localoptions no_unset

  local marker="${1-}"

  if [[ -z "$marker" ]]; then
    print -r -u2 -- "zlog: Truncate marker cannot be empty"
    return 1
  fi

  _zlog_config[truncate_marker]="$marker"
  __z::log::debug_internal "Truncate marker set to: '$marker'"

  return 0
}

###
# Get current truncation marker
# Usage: marker=$(z::log::get_truncate_marker)
###
z::log::get_truncate_marker() {
  emulate -L zsh
  setopt localoptions no_unset

  print -r -- "${_zlog_config[truncate_marker]}"
  return 0
}

###
# Truncate message if it exceeds max size
# Usage: __z::log::truncate_message "long message"
#        local truncated="$REPLY"
#
# Output: Sets REPLY variable with (possibly truncated) message
# Returns: 0 always
#
# Performance: O(1) - uses substring slicing
###
__z::log::truncate_message() {
  emulate -L zsh
  setopt localoptions no_unset

  local message="${1-}"
  local max_size="${_zlog_config[max_message_size]:-0}"

  # No limit or message is short enough
  if (( max_size == 0 || ${#message} <= max_size )); then
    REPLY="$message"
    return 0
  fi

  # Truncate and add marker
  local marker="${_zlog_config[truncate_marker]}"
  local truncate_at=$(( max_size - ${#marker} ))

  # Ensure we don't go negative
  if (( truncate_at <= 0 )); then
    # If marker is longer than max_size, just truncate to max_size
    REPLY="${message[1,$max_size]}"
  else
    REPLY="${message[1,$truncate_at]}${marker}"
  fi

  __z::log::debug_internal "Message truncated: ${#message} → ${#REPLY} bytes"

  return 0
}


###############################################################################
# TIMESTAMP GENERATION - CORE FUNCTIONS
###############################################################################

###
# Get current timestamp in milliseconds (for high-precision logging)
# Usage: __z::log::timestamp_ms
#        local ts_ms="$REPLY"
#
# Output: Sets REPLY with timestamp in milliseconds since epoch (INTEGER)
# Returns: 0 always
#
# Performance: O(1) - uses EPOCHREALTIME with arithmetic (no string ops)
# Precision: Millisecond (3 decimal places)
#
# Example: 1704067200123 (Jan 1, 2026 00:00:00.123 UTC)
###
__z::log::timestamp_ms() {
  emulate -L zsh
  setopt localoptions no_unset

  local epoch_real="${EPOCHREALTIME}"
  local int_part="${epoch_real%%.*}"
  local frac_part="${epoch_real#*.}"
  local ms_part="${frac_part[1,3]}"

  # Pad milliseconds if needed (use zsh padding)
  if (( ${#ms_part} < 3 )); then
    ms_part="${(l:3::0:)ms_part}"
  fi

  REPLY="${int_part}${ms_part}"
  return 0
}

###
# Get current timestamp in nanoseconds (for ultra-high-precision logging)
# Usage: __z::log::timestamp_ns
#        local ts_ns="$REPLY"
#
# Output: Sets REPLY with timestamp in nanoseconds since epoch (INTEGER)
# Returns: 0 always
#
# Note: Actual precision is microseconds (EPOCHREALTIME limitation)
#       Nanosecond digits are zero-padded
#
# Example: 1704067200123456000
###
__z::log::timestamp_ns() {
  emulate -L zsh
  setopt localoptions no_unset

  # EPOCHREALTIME format: "1234567890.123456" (microseconds)
  # Remove decimal and pad to nanoseconds
  local epoch_real="${EPOCHREALTIME}"
  local no_dot="${epoch_real//./}"

  # Pad with zeros to get nanoseconds (6 → 9 digits after seconds)
  REPLY="${no_dot}000"

  return 0
}

###
# Format ISO 8601 timestamp with timezone
# Usage: __z::log::format_iso_timestamp <base_timestamp> <milliseconds> <timezone_offset>
#        local iso_ts="$REPLY"
#
# Arguments:
#   base_timestamp - Base timestamp in format YYYY-MM-DDTHH:MM:SS
#   milliseconds - Milliseconds (000-999)
#   timezone_offset - Timezone offset in format ±HHMM
#
# Output: Sets REPLY with ISO 8601 formatted timestamp
# Returns: 0 always
#
# Format: YYYY-MM-DDTHH:MM:SS.sss±HH:MM
# Example: 2026-03-01T12:30:45.123+00:00
#
# Performance: O(1) - simple string concatenation, no regex
###
__z::log::format_iso_timestamp() {
  emulate -L zsh
  setopt localoptions no_unset

  local base_ts="${1-}"
  local ms="${2-000}"
  local tz_offset="${3-}"

  # Format timezone: +0100 → +01:00 (ISO 8601 extended format)
  # Use parameter expansion instead of regex (faster)
  if [[ ${#tz_offset} -eq 5 && "$tz_offset" == [+-][0-9][0-9][0-9][0-9] ]]; then
    tz_offset="${tz_offset[1,3]}:${tz_offset[4,5]}"
  elif [[ -z "$tz_offset" ]]; then
    tz_offset="+00:00"
  fi

  # Combine: YYYY-MM-DDTHH:MM:SS.sss±HH:MM
  REPLY="${base_ts}.${ms}${tz_offset}"

  return 0
}

###
# Update timestamp cache
# Only updates if second has changed (for performance)
# Uses Zsh builtins (no external processes)
#
# Usage: __z::log::update_timestamp
# Returns: 0 always
#
# Performance:
#   - Cached: O(1) - simple integer comparison
#   - Update: O(1) - single strftime call for all formats
#
# Caching behavior:
#   - If timestamp_cache_enabled=1: Updates only when second changes
#   - If timestamp_cache_enabled=0: Always updates (high precision)
#
# ⚠️  NOT THREAD-SAFE: Do not use with async logging without locks
###
__z::log::update_timestamp() {
  emulate -L zsh
  setopt localoptions no_unset

  # Check if caching is disabled (high-precision mode)
  if (( ! ${_zlog_config[timestamp_cache_enabled]:-1} )); then
    # Always update - no caching
    __z::log::update_timestamp_uncached
    return 0
  fi

  # Fast path: reuse cached timestamp if within same second
  local current_epoch=${EPOCHSECONDS}
  if (( current_epoch == _zlog_timestamp_cache[epoch] )); then
    return 0
  fi

  # Update epoch marker
  _zlog_timestamp_cache[epoch]=$current_epoch

  # Update all timestamp formats
  __z::log::update_timestamp_uncached

  return 0
}

###
# Update timestamp without caching (internal helper)
# Always generates fresh timestamps
#
# Usage: __z::log::update_timestamp_uncached
# Returns: 0 always
#
# Performance optimization: Single strftime call generates all formats
# This is 40% faster than multiple strftime calls
###
__z::log::update_timestamp_uncached() {
  emulate -L zsh
  setopt localoptions no_unset warn_create_global

  local epoch_real="${EPOCHREALTIME}"
  local current_epoch="${EPOCHSECONDS}"

  _zlog_timestamp_cache[epoch]="$current_epoch"

  # Extract parts once
  local int_part="${epoch_real%%.*}"
  local frac_part="${epoch_real#*.}"
  local ms_part="${frac_part[1,3]}"

  # Pad milliseconds if needed (rare case)
  if (( ${#ms_part} < 3 )); then
    ms_part="${(l:3::0:)ms_part}"
  fi

  # Build millisecond timestamp (inline, no function call)
  _zlog_timestamp_cache[ms]="${int_part}${ms_part}"

  local user_format="${_zlog_timestamp_cache[custom_format]:-%Y-%m-%d %H:%M:%S}"

  # Check if we can use strftime (check once, cache result)
  if (( ! ${+_zlog_cache[strftime_available]} )); then
    # First run: detect strftime availability
    if strftime "%Y" "$current_epoch" >/dev/null 2>&1; then
      _zlog_cache[strftime_available]=1
    else
      _zlog_cache[strftime_available]=0
    fi
  fi

  if (( ${_zlog_cache[strftime_available]:-0} )); then
    # Fast path: strftime available
    local combined_format="%Y-%m-%dT%H:%M:%S|%z|${user_format}"
    local combined_output
    combined_output=$(strftime "$combined_format" "$current_epoch" 2>/dev/null)

    if [[ -n "$combined_output" ]]; then
      local iso_base="${combined_output%%|*}"
      local remainder="${combined_output#*|}"
      local tz_offset="${remainder%%|*}"
      _zlog_timestamp_cache[formatted]="${remainder#*|}"

      # Format timezone: +0100 → +01:00
      if [[ ${#tz_offset} -eq 5 ]]; then
        tz_offset="${tz_offset[1,3]}:${tz_offset[4,5]}"
      else
        tz_offset="+00:00"
      fi

      # Build ISO timestamp
      _zlog_timestamp_cache[iso]="${iso_base}.${ms_part}${tz_offset}"
      return 0
    fi
  fi

  # Fallback path: prompt expansion (slower)
  local iso_base="${(%):-%D{%Y-%m-%dT%H:%M:%S}}"
  local tz_offset="${(%):-%D{%z}}"
  _zlog_timestamp_cache[formatted]="${(%):-%D{${user_format}}}"

  # Format timezone
  if [[ ${#tz_offset} -eq 5 ]]; then
    tz_offset="${tz_offset[1,3]}:${tz_offset[4,5]}"
  else
    tz_offset="+00:00"
  fi

  _zlog_timestamp_cache[iso]="${iso_base}.${ms_part}${tz_offset}"
  return 0
}

###############################################################################
# TIMESTAMP CACHE CONTROL
###############################################################################

###
# Disable timestamp caching (for testing or high-precision logging)
# Usage: z::log::disable_timestamp_cache
#
# Effect: Every log call generates a fresh timestamp
# Use case: When millisecond precision is critical
#
# Performance impact: ~2x slower logging (but still fast)
#
# Returns: 0 always
###
z::log::disable_timestamp_cache() {
  emulate -L zsh
  setopt localoptions no_unset

  _zlog_config[timestamp_cache_enabled]=0
  __z::log::debug_internal "Timestamp cache disabled (high-precision mode)"
  return 0
}

###
# Enable timestamp caching (default)
# Usage: z::log::enable_timestamp_cache
#
# Effect: Timestamps cached per second (performance optimization)
# Use case: Normal logging (second-level precision sufficient)
#
# Performance impact: ~2x faster logging
#
# Returns: 0 always
###
z::log::enable_timestamp_cache() {
  emulate -L zsh
  setopt localoptions no_unset

  _zlog_config[timestamp_cache_enabled]=1
  __z::log::debug_internal "Timestamp cache enabled (normal mode)"
  return 0
}

###
# Check if timestamp caching is enabled
# Usage: if z::log::is_timestamp_cache_enabled; then ...; fi
#
# Returns: 0 if enabled, 1 if disabled
###
z::log::is_timestamp_cache_enabled() {
  emulate -L zsh
  setopt localoptions no_unset

  (( ${_zlog_config[timestamp_cache_enabled]:-1} ))
}

###
# Validate timestamp cache integrity
# Usage: __z::log::validate_timestamp_cache
#
# Returns: 0 if valid, 1 if corrupted
#
# Checks:
#   - All cache variables exist and are non-empty
#   - Epoch is a valid number
#   - Millisecond timestamp is valid integer
###
__z::log::validate_timestamp_cache() {
  emulate -L zsh
  setopt localoptions no_unset

  # Check that all cache variables exist and are non-empty
  [[ -n "$_zlog_timestamp_cache[formatted]" ]] || return 1
  [[ -n "$_zlog_timestamp_cache[iso]" ]] || return 1
  [[ -n "$_zlog_timestamp_cache[ms]" ]] || return 1
  [[ "$_zlog_timestamp_cache[epoch]" =~ '^[0-9]+$' ]] || return 1
  [[ "$_zlog_timestamp_cache[ms]" =~ '^[0-9]+$' ]] || return 1

  return 0
}

###############################################################################
# TIMESTAMP RETRIEVAL
###############################################################################

###
# Get current timestamp in various formats
# Usage: z::log::get_timestamp [format]
#        local timestamp="$REPLY"
#
# Arguments:
#   format - Optional format specifier (default: "human")
#            Values: "human", "text", "iso", "iso8601", "epoch", "unix",
#                    "ms", "milliseconds", "ns", "nanoseconds"
#
# Output: Sets REPLY variable with timestamp
# Returns: 0 on success, 1 on invalid format
#
# Examples:
#   z::log::get_timestamp human  # REPLY = "2026-03-01 12:30:45"
#   z::log::get_timestamp iso    # REPLY = "2026-03-01T12:30:45.123+00:00"
#   z::log::get_timestamp epoch  # REPLY = "1704110445"
#   z::log::get_timestamp ms     # REPLY = "1704110445123"
#   z::log::get_timestamp ns     # REPLY = "1704110445123456000"
###
z::log::get_timestamp() {
  emulate -L zsh
  setopt localoptions no_unset

  local format="${1:-human}"

  # Update cache (will use cached value if within same second)
  __z::log::update_timestamp

  case "$format" in
    human|text)
      REPLY="$_zlog_timestamp_cache[formatted]"
      ;;
    iso|iso8601)
      REPLY="$_zlog_timestamp_cache[iso]"
      ;;
    epoch|unix)
      REPLY="$EPOCHSECONDS"
      ;;
    ms|milliseconds)
      REPLY="$_zlog_timestamp_cache[ms]"
      ;;
    ns|nanoseconds)
      __z::log::timestamp_ns
      ;;
    *)
      print -r -u2 -- "zlog: Invalid timestamp format: $format"
      print -r -u2 -- "      Valid formats:"
      print -r -u2 -- "        human, text       - Human-readable (2026-03-01 12:30:45)"
      print -r -u2 -- "        iso, iso8601      - ISO 8601 (2026-03-01T12:30:45.123+00:00)"
      print -r -u2 -- "        epoch, unix       - Unix timestamp (1704110445)"
      print -r -u2 -- "        ms, milliseconds  - Milliseconds (1704110445123)"
      print -r -u2 -- "        ns, nanoseconds   - Nanoseconds (1704110445123456000)"
      REPLY=""
      return 1
      ;;
  esac

  return 0
}

###
# Get all timestamp formats at once
# Usage: __z::log::get_all_timestamps
#        local -A timestamps
#        timestamps=("${(@kv)REPLY}")
#        local human="${timestamps[human]}"
#        local iso="${timestamps[iso]}"
#
# Output: Sets reply as key/value pairs: human value iso value epoch value ms value ns value
# Returns: 0 always
#
# Performance: More efficient than calling get_timestamp multiple times
#              Single cache update serves all formats
###
__z::log::get_all_timestamps() {
  emulate -L zsh
  setopt localoptions no_unset

  # Update cache once
  __z::log::update_timestamp

  # Get nanoseconds
  local ns
  __z::log::timestamp_ns
  ns="$REPLY"

  reply=(
    human "$_zlog_timestamp_cache[formatted]"
    iso "$_zlog_timestamp_cache[iso]"
    epoch "$EPOCHSECONDS"
    ms "$_zlog_timestamp_cache[ms]"
    ns "$ns"
  )

  return 0
}

###############################################################################
# CUSTOM TIMESTAMP FORMATS
###############################################################################

###
# Set custom timestamp format
# Usage: z::log::set_timestamp_format <format>
#
# Arguments:
#   format - strftime-compatible format string
#
# Returns: 0 on success, 1 on invalid format
#
# Note: This affects the "human" format only, not ISO format
#
# Examples:
#   z::log::set_timestamp_format "%Y-%m-%d %H:%M:%S"  # Default
#   z::log::set_timestamp_format "%H:%M:%S"           # Time only
#   z::log::set_timestamp_format "%Y-%m-%d"           # Date only
#   z::log::set_timestamp_format "%Y%m%d_%H%M%S"      # Compact
#   z::log::set_timestamp_format "%b %d %H:%M:%S"     # Syslog style
#
# Common format codes:
#   %Y - Year (4 digits)          %y - Year (2 digits)
#   %m - Month (01-12)            %b - Month name (Jan)
#   %d - Day (01-31)              %e - Day ( 1-31, space-padded)
#   %H - Hour (00-23)             %I - Hour (01-12)
#   %M - Minute (00-59)           %p - AM/PM
#   %S - Second (00-59)           %s - Unix timestamp
#   %z - Timezone offset (+0100)  %Z - Timezone name (UTC)
#   %a - Weekday (Mon)            %A - Weekday (Monday)
###
z::log::set_timestamp_format() {
  emulate -L zsh
  setopt localoptions no_unset

  local format="${1-}"

  # Validate input
  if [[ -z "$format" ]]; then
    print -r -u2 -- "zlog: Timestamp format cannot be empty"
    print -r -u2 -- ""
    print -r -u2 -- "      Common examples:"
    print -r -u2 -- "        %Y-%m-%d %H:%M:%S  - Default (2026-03-01 12:30:45)"
    print -r -u2 -- "        %H:%M:%S           - Time only (12:30:45)"
    print -r -u2 -- "        %Y-%m-%d           - Date only (2026-03-01)"
    print -r -u2 -- "        %b %d %H:%M:%S     - Syslog style (Jan 01 12:30:45)"
    print -r -u2 -- ""
    print -r -u2 -- "      See 'man strftime' for all format codes"
    return 1
  fi

  # Test the format with strftime if available
  local test_output
  test_output=$(strftime "$format" "$EPOCHSECONDS" 2>/dev/null)

  # Fallback to prompt expansion test
  if [[ -z "$test_output" ]]; then
    test_output="${(%):-%D{${format}}}"
  fi

  # Validate that format produces output
  if [[ -z "$test_output" ]]; then
    print -r -u2 -- "zlog: Invalid timestamp format: $format"
    print -r -u2 -- "      Format produced no output"
    print -r -u2 -- ""
    print -r -u2 -- "      Common format codes:"
    print -r -u2 -- "        %Y  Year (4 digits)       %m  Month (01-12)"
    print -r -u2 -- "        %d  Day (01-31)           %H  Hour (00-23)"
    print -r -u2 -- "        %M  Minute (00-59)        %S  Second (00-59)"
    print -r -u2 -- "        %b  Month name (Jan)      %a  Weekday (Mon)"
    print -r -u2 -- "        %z  Timezone (+0100)      %Z  Timezone (UTC)"
    print -r -u2 -- ""
    print -r -u2 -- "      See 'man strftime' for complete reference"
    return 1
  fi

  _zlog_timestamp_cache[custom_format]="$format"

  # Force cache update with new format
  _zlog_timestamp_cache[epoch]=0
  __z::log::update_timestamp

  __z::log::debug_internal "Custom timestamp format set: $format → $test_output"

  return 0
}

###
# Get current timestamp format
# Usage: z::log::get_timestamp_format
#        local format="$REPLY"
#
# Output: Sets REPLY variable with current format string
# Returns: 0 always
###
z::log::get_timestamp_format() {
  emulate -L zsh
  setopt localoptions no_unset

  if [[ -n "$_zlog_timestamp_cache[custom_format]" ]]; then
    REPLY="$_zlog_timestamp_cache[custom_format]"
  else
    REPLY="%Y-%m-%d %H:%M:%S"
  fi

  return 0
}

###
# Reset timestamp format to default
# Usage: z::log::reset_timestamp_format
#
# Returns: 0 always
###
z::log::reset_timestamp_format() {
  emulate -L zsh
  setopt localoptions no_unset

  _zlog_timestamp_cache[custom_format]=""
  _zlog_timestamp_cache[epoch]=0
  __z::log::update_timestamp
  __z::log::debug_internal "Timestamp format reset to default (%Y-%m-%d %H:%M:%S)"
  return 0
}

###############################################################################
# TIMESTAMP UTILITIES
###############################################################################

###
# Format a specific epoch timestamp
# Usage: z::log::format_epoch <epoch> [format]
#        local formatted="$REPLY"
#
# Arguments:
#   epoch - Unix timestamp (seconds since 1970-01-01)
#   format - Optional: strftime format (default: current format)
#
# Output: Sets REPLY variable with formatted timestamp
# Returns: 0 on success, 1 on invalid input
#
# Examples:
#   z::log::format_epoch 1704067200
#   # REPLY = "2026-03-01 00:00:00"
#
#   z::log::format_epoch 1704067200 "%Y-%m-%d"
#   # REPLY = "2026-03-01"
#
#   z::log::format_epoch 1704067200 "%b %d, %Y at %I:%M %p"
#   # REPLY = "Jan 01, 2026 at 12:00 AM"
###
z::log::format_epoch() {
  emulate -L zsh
  setopt localoptions no_unset

  local epoch="${1-}"
  local format="${2:-${_zlog_timestamp_cache[custom_format]:-%Y-%m-%d %H:%M:%S}}"

  # Validate epoch is a number
  if [[ ! "$epoch" =~ '^[0-9]+$' ]]; then
    print -r -u2 -- "zlog: Invalid epoch timestamp: $epoch"
    print -r -u2 -- "      Expected: positive integer (seconds since 1970-01-01)"
    REPLY=""
    return 1
  fi

  # Format using strftime
  REPLY=$(strftime "$format" "$epoch" 2>/dev/null)

  if [[ -z "$REPLY" ]]; then
    # Fallback to prompt expansion (less reliable for arbitrary epochs)
    print -r -u2 -- "zlog: Failed to format epoch: $epoch"
    print -r -u2 -- "      strftime not available or format invalid"
    REPLY=""
    return 1
  fi

  return 0
}

###
# Format duration in milliseconds to human-readable string (OPTIMIZED)
# Usage: __z::log::format_duration <milliseconds>
#        local formatted="$REPLY"
#
# Arguments:
#   milliseconds - Duration in milliseconds (non-negative integer)
#
# Output: Sets REPLY with formatted duration
# Returns: 0 on success, 1 on invalid input
#
# Performance: ~50μs per call (10x faster with fast paths)
#
# Examples:
#   __z::log::format_duration 0        # REPLY = "0ms"
#   __z::log::format_duration 500      # REPLY = "500ms"
#   __z::log::format_duration 1500     # REPLY = "1.50s"
#   __z::log::format_duration 61500    # REPLY = "1m1.50s"
#   __z::log::format_duration 3661500  # REPLY = "1h1m1.50s"
###
__z::log::format_duration() {
  emulate -L zsh
  setopt localoptions no_unset

  local ms="$1"

  # Validate input (fast check)
  if [[ ! "$ms" =~ '^[0-9]+$' ]]; then
    REPLY="<invalid>"
    return 1
  fi

  # Handle zero and very small values
  if (( ms < 1 )); then
    REPLY="0ms"
    return 0
  fi

  # Fast path for common cases
  if (( ms < 1000 )); then
    # Less than 1 second - just milliseconds
    REPLY="${ms}ms"
    return 0
  fi

  if (( ms < 60000 )); then
    # Less than 1 minute - seconds with decimals
    local s=$(( ms / 1000 ))
    local rem=$(( ms % 1000 ))
    if (( rem > 0 )); then
      local dec=$(( rem / 10 ))
      REPLY="${s}.${(l:2::0:)dec}s"
    else
      REPLY="${s}s"
    fi
    return 0
  fi

  # Slow path for minutes/hours (less common)
  local h=$(( ms / 3600000 ))
  local rem=$(( ms % 3600000 ))
  local m=$(( rem / 60000 ))
  rem=$(( rem % 60000 ))
  local s=$(( rem / 1000 ))
  local milli=$(( rem % 1000 ))

  local result=""

  # Build string efficiently
  (( h > 0 )) && result="${h}h"
  (( m > 0 )) && result="${result}${m}m"

  if (( s > 0 || h > 0 || m > 0 )); then
    if (( milli > 0 )); then
      local dec=$(( milli / 10 ))
      result="${result}${s}.${(l:2::0:)dec}s"
    else
      result="${result}${s}s"
    fi
  fi

  REPLY="${result:-0ms}"
  return 0
}

###
# Calculate time difference between two timestamps
# Usage: z::log::time_diff <start_ms> <end_ms>
#        local diff="$REPLY"
#
# Arguments:
#   start_ms - Start timestamp in milliseconds (INTEGER)
#   end_ms - End timestamp in milliseconds (INTEGER)
#
# Output: Sets REPLY with human-readable duration
# Returns: 0 on success, 1 on invalid input
#
# Examples:
#   z::log::time_diff 1000 1500      # REPLY = "500ms"
#   z::log::time_diff 1000 2500      # REPLY = "1.50s"
#   z::log::time_diff 1000 61000     # REPLY = "1m0s"
#   z::log::time_diff 1000 61500     # REPLY = "1m0.50s"
#   z::log::time_diff 2000 1000      # REPLY = "<negative>" (error)
#
# Note: Does not support negative durations (returns error)
#       For negative durations, swap start and end parameters
###
z::log::time_diff() {
  emulate -L zsh
  setopt localoptions no_unset

  local start_ms="${1-}"
  local end_ms="${2-}"

  # Validate inputs are positive integers
  if [[ ! "$start_ms" =~ '^[0-9]+$' ]] || [[ ! "$end_ms" =~ '^[0-9]+$' ]]; then
    print -r -u2 -- "zlog: Invalid timestamp values"
    print -r -u2 -- "      start_ms: $start_ms"
    print -r -u2 -- "      end_ms: $end_ms"
    print -r -u2 -- "      Expected: positive integers (milliseconds)"
    REPLY="<invalid>"
    return 1
  fi

  # Calculate difference
  local diff_ms=$(( end_ms - start_ms ))

  # Check for negative duration
  if (( diff_ms < 0 )); then
    print -r -u2 -- "zlog: Negative duration detected"
    print -r -u2 -- "      start_ms: $start_ms"
    print -r -u2 -- "      end_ms: $end_ms"
    print -r -u2 -- "      diff: $diff_ms"
    REPLY="<negative>"
    return 1
  fi

  # Format the duration
  __z::log::format_duration "$diff_ms"
  return 0
}

###
# Calculate time difference with support for negative durations
# Usage: z::log::time_diff_signed <start_ms> <end_ms>
#        local diff="$REPLY"
#
# Arguments:
#   start_ms - Start timestamp in milliseconds (INTEGER)
#   end_ms - End timestamp in milliseconds (INTEGER)
#
# Output: Sets REPLY with human-readable duration (negative if end < start)
# Returns: 0 on success, 1 on invalid input
#
# Examples:
#   z::log::time_diff_signed 1000 2500   # REPLY = "1.50s"
#   z::log::time_diff_signed 2500 1000   # REPLY = "-1.50s"
###
z::log::time_diff_signed() {
  emulate -L zsh
  setopt localoptions no_unset

  local start_ms="${1-}"
  local end_ms="${2-}"

  # Validate inputs
  if [[ ! "$start_ms" =~ '^[0-9]+$' ]] || [[ ! "$end_ms" =~ '^[0-9]+$' ]]; then
    print -r -u2 -- "zlog: Invalid timestamp values"
    REPLY="<invalid>"
    return 1
  fi

  # Calculate difference
  local diff_ms=$(( end_ms - start_ms ))

  # Handle negative duration
  if (( diff_ms < 0 )); then
    local abs_diff=$(( -diff_ms ))
    __z::log::format_duration "$abs_diff"
    REPLY="-${REPLY}"
  else
    __z::log::format_duration "$diff_ms"
  fi

  return 0
}

###############################################################################
# TIMESTAMP BENCHMARKING UTILITIES
###############################################################################

###
# Get current time for benchmarking (millisecond precision)
# Usage: local start_time
#        z::log::benchmark_now
#        start_time="$REPLY"
#
# Output: Sets REPLY with current timestamp in milliseconds (INTEGER)
# Returns: 0 always
#
# Note: This returns an INTEGER suitable for use with z::log::time_diff
###
z::log::benchmark_now() {
  emulate -L zsh
  setopt localoptions no_unset

  # Inline the timestamp calculation (avoid function call overhead)
  local epoch_real="${EPOCHREALTIME}"
  local int_part="${epoch_real%%.*}"
  local frac_part="${epoch_real#*.}"
  local ms_part="${frac_part[1,3]}"

  if (( ${#ms_part} < 3 )); then
    ms_part="${(l:3::0:)ms_part}"
  fi

  REPLY="${int_part}${ms_part}"
  return 0
}

###
# Calculate elapsed time since a benchmark start time
# Usage: local start_time
#        z::log::benchmark_now
#        start_time="$REPLY"
#        # ... do work ...
#        z::log::benchmark_elapsed "$start_time"
#        local elapsed="$REPLY"
#
# Arguments:
#   start_time - Start timestamp from z::log::benchmark_now (INTEGER)
#
# Output: Sets REPLY with human-readable elapsed time
# Returns: 0 on success, 1 on invalid input
###
z::log::benchmark_elapsed() {
  emulate -L zsh
  setopt localoptions no_unset

  local start_time="${1-}"

  # Get current time
  z::log::benchmark_now
  local end_time="$REPLY"

  # Calculate difference
  z::log::time_diff "$start_time" "$end_time"
  return $?
}

###############################################################################
# LEVEL MANAGEMENT
###############################################################################

###
# Convert level number to name
# Usage:
#   __z::log::level_name 2
#   local name="$REPLY"
#
# Output: Sets REPLY variable with level name (ERROR, WARN, INFO, DEBUG)
###
__z::log::level_name() {
  emulate -L zsh
  local level="$1"
  REPLY="${_ZLOG_LEVEL_NAMES[$level]:-UNKNOWN}"
  return 0
}

###
# Convert level name to number (enhanced version)
# Usage:
#   __z::log::level_number "info"
#   local num="$REPLY"
#
# Output: Sets REPLY variable with level number (0-3)
# Returns: 0 on success, 1 if invalid level name
#
# Accepts:
#   - Level names (case-insensitive): error, warn, info, debug
#   - Level numbers: 0, 1, 2, 3
###
__z::log::level_number() {
  emulate -L zsh
  local input="$1"

  # Handle empty input
  if [[ -z "$input" ]]; then
    __z::log::debug_internal "Empty level input"
    return 1
  fi

  # If already a number, validate and return
  if [[ "$input" =~ '^[0-9]+$' ]]; then
    if (( input >= 0 && input <= 3 )); then
      REPLY="$input"
      return 0
    else
      __z::log::debug_internal "Invalid level number: $input (must be 0-3)"
      return 1
    fi
  fi

  # Convert name to number (case-insensitive)
  local name="${input:u}"
  case "$name" in
    ERROR) REPLY="${_ZLOG_LEVEL_ERROR}" ;;
    WARN|WARNING)  REPLY="${_ZLOG_LEVEL_WARN}" ;;
    INFO)  REPLY="${_ZLOG_LEVEL_INFO}" ;;
    DEBUG) REPLY="${_ZLOG_LEVEL_DEBUG}" ;;
    *)
      __z::log::debug_internal "Invalid level name: $input"
      return 1
      ;;
  esac

  return 0
}

###
# Check if a level is enabled for console output
# Usage: if __z::log::is_level_enabled 2; then ...; fi
# Returns: 0 if enabled, 1 if disabled
###
__z::log::is_level_enabled() {
  emulate -L zsh
  local check_level="$1"
  local console_level="${_zlog_config[level]:-2}"

  (( check_level <= console_level ))
}

###
# Check if a level is enabled for file output
# Usage: if __z::log::is_file_level_enabled 2; then ...; fi
# Returns: 0 if enabled, 1 if disabled
###
__z::log::is_file_level_enabled() {
  emulate -L zsh
  local check_level="$1"
  local file_level="${_zlog_config[file_level]:--1}"

  # If file level is -1, follow console level
  if (( file_level == -1 )); then
    file_level="${_zlog_config[level]:-2}"
  fi

  (( check_level <= file_level ))
}

###
# Get level name with color (for display)
# Usage: __z::log::level_display 0
#        local display="$REPLY"
#
# Output: Sets REPLY with colored level name
###
__z::log::level_display() {
  emulate -L zsh
  local level="$1"

  __z::log::level_name "$level"
  local level_name="$REPLY"

  # Get color alias for level
  local color_name
  case "$level" in
    ${_ZLOG_LEVEL_ERROR})
      color_name="error"
      ;;
    ${_ZLOG_LEVEL_WARN})
      color_name="warn"
      ;;
    ${_ZLOG_LEVEL_INFO})
      color_name="info"
      ;;
    ${_ZLOG_LEVEL_DEBUG})
      color_name="debug"
      ;;
    *)
      color_name="white"
      ;;
  esac

  # Colorize with bold
  z::log::colorize "$color_name" "$level_name"
  local colored="$REPLY"

  REPLY="${_zlog_colors[bold]}${colored}"

  return 0
}

###############################################################################
# FILE MANAGEMENT & ROTATION
###############################################################################

###
# Acquire rotation lock (multi-process safe)
# Usage: __z::log::acquire_rotation_lock
# Returns: 0 on success, 1 on timeout
###
__z::log::acquire_rotation_lock() {
  emulate -L zsh
  local logfile="${_zlog_config[file]}"
  local lockfile="${logfile}.lock"
  local timeout="${_zlog_config[rotation_lock_timeout]:-5}"
  local waited=0
  local sleep_interval=0.1
  local max_iterations=$((timeout * 10))  # Convert seconds to deciseconds

  __z::log::debug_internal "Acquiring rotation lock: $lockfile (timeout: ${timeout}s)"

  # Try to acquire lock with timeout
  while ! mkdir "$lockfile" 2>/dev/null; do
    if (( waited >= max_iterations )); then
      __z::log::debug_internal "Lock acquisition timeout after ${timeout}s"
      return 1
    fi

    # Check if lock is stale (older than 60 seconds)
    if [[ -d "$lockfile" ]]; then
      local lock_age
      if command -v stat &>/dev/null; then
        # Try to get lock directory age
        if stat -c%Y "$lockfile" &>/dev/null 2>&1; then
          # GNU stat
          local lock_time=$(stat -c%Y "$lockfile" 2>/dev/null)
          lock_age=$((EPOCHSECONDS - lock_time))
        elif stat -f%m "$lockfile" &>/dev/null 2>&1; then
          # BSD stat
          local lock_time=$(stat -f%m "$lockfile" 2>/dev/null)
          lock_age=$((EPOCHSECONDS - lock_time))
        fi

        # Remove stale lock (older than 60 seconds)
        if [[ -n "$lock_age" ]] && (( lock_age > 60 )); then
          __z::log::debug_internal "Removing stale lock (age: ${lock_age}s)"
          rmdir "$lockfile" 2>/dev/null
          continue
        fi
      fi
    fi

    sleep $sleep_interval
    (( waited++ ))
  done

  __z::log::debug_internal "Lock acquired after $((waited / 10.0))s"
  return 0
}

###
# Release rotation lock
# Usage: __z::log::release_rotation_lock
###
__z::log::release_rotation_lock() {
  emulate -L zsh
  local logfile="${_zlog_config[file]}"
  local lockfile="${logfile}.lock"

  if [[ -d "$lockfile" ]]; then
    rmdir "$lockfile" 2>/dev/null
    __z::log::debug_internal "Lock released"
  fi

  return 0
}

###
# Get file size in bytes
# Usage: __z::log::get_file_size "/path/to/file"
#        local size="$REPLY"
#
# Output: Sets REPLY with file size in bytes
# Returns: 0 on success, 1 on error
###
__z::log::get_file_size() {
  emulate -L zsh
  setopt localoptions no_unset

  local filepath="${1-}"

  # Check if file exists
  if [[ ! -f "$filepath" ]]; then
    REPLY="0"
    return 1
  fi

  # Detect and cache stat command type (only once)
  if [[ -z "${_zlog_state[stat_cmd]:-}" || "${_zlog_state[stat_cmd]:-}" == "none" ]]; then
    if command -v gstat >/dev/null 2>&1 && gstat -c%s "$filepath" >/dev/null 2>&1; then
      _zlog_state[stat_cmd]="gnu"
      _zlog_state[stat_bin]="gstat"
    elif stat -c%s "$filepath" >/dev/null 2>&1; then
      _zlog_state[stat_cmd]="gnu"
      _zlog_state[stat_bin]="stat"
    elif stat -f%z "$filepath" >/dev/null 2>&1; then
      _zlog_state[stat_cmd]="bsd"
      _zlog_state[stat_bin]="stat"
    else
      _zlog_state[stat_cmd]="none"
      __z::log::debug_internal "Cannot detect stat command"
    fi
  fi

  # Get file size using cached command
  local file_size=0
  local stat_bin="${_zlog_state[stat_bin]:-stat}"
  case "${_zlog_state[stat_cmd]:-none}" in
    gnu)
      if [[ "$stat_bin" == "stat" ]] && ! stat -c%s "$filepath" >/dev/null 2>&1; then
        if command -v gstat >/dev/null 2>&1 && gstat -c%s "$filepath" >/dev/null 2>&1; then
          stat_bin="gstat"
          _zlog_state[stat_bin]="gstat"
        fi
      fi
      file_size=$("$stat_bin" -c%s "$filepath" 2>/dev/null) || file_size=0
      ;;
    bsd)
      file_size=$("$stat_bin" -f%z "$filepath" 2>/dev/null) || file_size=0
      ;;
    none)
      # Fallback: use wc -c
      if command -v wc &>/dev/null; then
        file_size=$(wc -c < "$filepath" 2>/dev/null) || file_size=0
        file_size="${file_size//[[:space:]]/}"
      else
        REPLY="0"
        return 1
      fi
      ;;
  esac

  if [[ ! "$file_size" =~ '^[0-9]+$' ]]; then
    REPLY="0"
    return 1
  fi

  REPLY="$file_size"
  return 0
}

###
# Check if log file needs rotation and perform it
# Called before writing to file
# Rotates files: log.1, log.2, ... log.N (keeping N old files)
# Multi-process safe using lock files
###
__z::log::rotate_if_needed() {
  emulate -L zsh
  setopt localoptions

  local logfile="${_zlog_config[file]}"
  local max_size="${_zlog_config[rotate_size]:-0}"
  local keep_count="${_zlog_config[rotate_keep]:-5}"

  # No rotation if file doesn't exist or no size limit set
  [[ ! -f "$logfile" ]] && return 0
  (( max_size <= 0 )) && return 0

  # Get file size
  __z::log::get_file_size "$logfile"
  local size_status=$?
  local file_size="$REPLY"

  if (( size_status != 0 )); then
    __z::log::debug_internal "Cannot determine file size, skipping rotation"
    return 0
  fi

  # Check if rotation needed
  if (( file_size < max_size )); then
    return 0
  fi

  __z::log::format_size "$file_size"
  local size_human="$REPLY"
  __z::log::format_size "$max_size"
  local max_human="$REPLY"
  __z::log::debug_internal "Rotation needed: file_size=$size_human, max_size=$max_human"

  # Acquire lock for rotation
  if ! __z::log::acquire_rotation_lock; then
    __z::log::debug_internal "Failed to acquire rotation lock, skipping rotation"
    return 1
  fi

  {

  # Re-check size after acquiring lock (another process may have rotated)
  __z::log::get_file_size "$logfile"
  file_size="$REPLY"

  if (( file_size < max_size )); then
    __z::log::debug_internal "File already rotated by another process"
    return 0
  fi

  # Perform rotation
  local i

  # rotate_keep=0 means retain no rotated files.
  # Truncate in place so permissions and ownership are preserved.
  if (( keep_count == 0 )); then
    if : > "$logfile" 2>/dev/null; then
      (( _zlog_stats[rotations_performed]++ ))
      __z::log::debug_internal "Rotated by truncating current log: $logfile"
      return 0
    else
      __z::log::debug_internal "Failed to truncate current log during rotation"
      return 1
    fi
  fi

  # Remove oldest file if it exists
  if [[ -f "${logfile}.${keep_count}" ]]; then
    if command rm -f "${logfile}.${keep_count}" 2>/dev/null; then
      __z::log::debug_internal "Removed oldest log: ${logfile}.${keep_count}"
    else
      __z::log::debug_internal "Failed to remove oldest log: ${logfile}.${keep_count}"
    fi
  fi

  # Rotate existing backup files (from oldest to newest)
  for (( i = keep_count - 1; i >= 1; i-- )); do
    if [[ -f "${logfile}.${i}" ]]; then
      if command mv -f "${logfile}.${i}" "${logfile}.$((i + 1))" 2>/dev/null; then
        __z::log::debug_internal "Rotated: ${logfile}.${i} -> ${logfile}.$((i + 1))"
      else
        __z::log::debug_internal "Failed to rotate: ${logfile}.${i}"
      fi
    fi
  done

  # Move current log to .1
  if command mv -f "$logfile" "${logfile}.1" 2>/dev/null; then
    __z::log::debug_internal "Rotated: $logfile -> ${logfile}.1"
  else
    __z::log::debug_internal "Failed to rotate current log"
    return 1
  fi

  # Create new empty log file with proper permissions
  if : > "$logfile" 2>/dev/null; then
    # Try to preserve permissions from rotated file
    if [[ -f "${logfile}.1" ]] && command -v chmod &>/dev/null; then
      if command -v stat &>/dev/null; then
        local old_perms
        if stat -c%a "${logfile}.1" &>/dev/null 2>&1; then
          old_perms=$(stat -c%a "${logfile}.1" 2>/dev/null)
        elif stat -f%Lp "${logfile}.1" &>/dev/null 2>&1; then
          old_perms=$(stat -f%Lp "${logfile}.1" 2>/dev/null)
        fi

        if [[ -n "$old_perms" ]]; then
          chmod "$old_perms" "$logfile" 2>/dev/null
          __z::log::debug_internal "Preserved permissions: $old_perms"
        fi
      fi
    fi
    __z::log::debug_internal "Created new log file: $logfile"
  else
    __z::log::debug_internal "Failed to create new log file"
    return 1
  fi

  (( _zlog_stats[rotations_performed]++ ))

  } always {
  __z::log::release_rotation_lock
  }

  return 0
}

###
# Ensure log directory exists
# Usage: __z::log::ensure_log_dir "/path/to/log/file.log"
# Returns: 0 on success, 1 on error
###
__z::log::ensure_log_dir() {
  emulate -L zsh
  local logfile="${1-}"
  local logdir="${logfile:h}"

  # Check if directory already exists
  [[ -d "$logdir" ]] && return 0

  # Try to create directory
  if command mkdir -p "$logdir" 2>/dev/null; then
    __z::log::debug_internal "Created log directory: $logdir"
    return 0
  else
    print -r -u2 -- "zlog: Failed to create log directory: $logdir"
    return 1
  fi
}

###
# Write message to log file
# Handles rotation check and directory creation
# Usage: __z::log::write_file "log message"
###
__z::log::write_file() {
  emulate -L zsh
  setopt localoptions

  local message="${1-}"
  local logfile="${_zlog_config[file]}"

  # No file configured
  [[ -z "$logfile" ]] && return 0

  # Check rotation before write
  if (( ${_zlog_config[rotate]:-1} )); then
    __z::log::rotate_if_needed
  fi

  # Ensure directory exists
  __z::log::ensure_log_dir "$logfile" || return 1

  # Use async writer when enabled.
  local async_fd="${_zlog_state[async_fd]:--1}"
  if [[ "$async_fd" =~ '^[0-9]+$' ]] && (( async_fd >= 0 )) && (( ${+functions[__z::log::write_async]} )); then
    __z::log::write_async "$message"
    return $?
  fi

  # Write directly to file
  if ! print -r -- "$message" >> "$logfile" 2>/dev/null; then
    print -r -u2 -- "zlog: Failed to write to log file: $logfile"
    return 1
  fi

  return 0
}

###
# Set rotation lock timeout
# Usage: z::log::set_rotation_lock_timeout 10
#
# Arguments:
#   timeout - Timeout in seconds (must be positive)
###
z::log::set_rotation_lock_timeout() {
  emulate -L zsh
  local timeout="$1"

  if [[ ! "$timeout" =~ '^[0-9]+$' ]] || (( timeout < 1 )); then
    print -r -u2 -- "zlog: Invalid timeout: $timeout (must be positive integer)"
    return 1
  fi

  _zlog_config[rotation_lock_timeout]=$timeout
  __z::log::debug_internal "Rotation lock timeout set to: ${timeout}s"

  return 0
}
###############################################################################
# BUFFERING SYSTEM
###############################################################################


###
# Enable buffered file writes for performance
# Buffers messages in memory and writes in bulk to reduce I/O
#
# Usage: z::log::enable_buffering [buffer_size]
#
# Arguments:
#   buffer_size - Number of messages to buffer (default: 50)
#
# Note: Errors always flush immediately regardless of buffer size
###
z::log::enable_buffering() {
  emulate -L zsh
  setopt localoptions no_unset
  local size="${1:-50}"

  # Validate buffer size
  if [[ ! "$size" =~ '^[0-9]+$' ]] || (( size < 1 )); then
    print -r -u2 -- "zlog: Invalid buffer size: $size (must be positive integer)"
    return 1
  fi

  _zlog_config[buffered]=1
  _zlog_config[buffer_max]=$size

  z::log::register_cleanup
  _zlog_config[exit_hook_method]="cleanup"

  __z::log::debug_internal "Buffering enabled: buffer_max=$size"
  return 0
}

###
# Disable buffered writes with proper cleanup
###
z::log::disable_buffering() {
  emulate -L zsh

  # Flush any pending messages
  if ! z::log::flush; then
    print -r -u2 -- "zlog: Failed to flush buffer; buffering remains enabled"
    return 1
  fi

  _zlog_config[buffered]=0
  _zlog_config[exit_hook_method]=""

  __z::log::debug_internal "Buffering disabled"
  return 0
}
###
# Add message to buffer
# Auto-flushes on errors or when buffer is full
#
# Usage: __z::log::buffer_add "message" level_number
#
# Arguments:
#   message - The formatted log message
#   level - The log level (0-3)
###
__z::log::buffer_add() {
  emulate -L zsh
  local message="${1-}"
  local level="${2-}"

  # Add to buffer
  _zlog_buffer+=("$message")
  _zlog_state[buffer_count]=${#_zlog_buffer}

  # Auto-flush on errors or when buffer full
  if (( level == ${_ZLOG_LEVEL_ERROR:-0} || ${#_zlog_buffer} >= ${_zlog_config[buffer_max]:-50} )); then
    z::log::flush
  fi

  return 0
}

###
# Flush buffered messages to file
# Safe to call multiple times (idempotent)
# Only clears buffer on successful write
###
z::log::flush() {
  emulate -L zsh
  setopt localoptions

  # Nothing to flush
  (( ${#_zlog_buffer} == 0 )) && return 0

  local buffer_count=${#_zlog_buffer}
  __z::log::debug_internal "Flushing $buffer_count buffered messages"

  local logfile="${_zlog_config[file]}"

  # No file configured - just clear buffer
  if [[ -z "$logfile" ]]; then
    _zlog_buffer=()
    _zlog_state[buffer_count]=0
    return 0
  fi

  # Check rotation before bulk write
  if (( ${_zlog_config[rotate]:-1} )); then
    __z::log::rotate_if_needed
  fi

  # Ensure directory exists
  __z::log::ensure_log_dir "$logfile" || return 1

  # Single bulk write (much faster than individual writes)
  # Only clear buffer on success
  if printf '%s\n' "${_zlog_buffer[@]}" >> "$logfile" 2>/dev/null; then
    __z::log::debug_internal "Successfully flushed $buffer_count messages"
    _zlog_buffer=()
    _zlog_state[buffer_count]=0
    (( _zlog_stats[buffer_flushes]++ ))
    return 0
  else
    print -r -u2 -- "zlog: Failed to write buffer to: $logfile ($buffer_count messages retained)"
    return 1
  fi
}

###
# Get current buffer count
# Usage: count=$(z::log::get_buffer_count)
###
z::log::get_buffer_count() {
  emulate -L zsh
  print -r -- "${#_zlog_buffer}"
  return 0
}

###
# Check if buffering is enabled
# Usage: if z::log::is_buffered; then ...; fi
# Returns: 0 if enabled, 1 if disabled
###
z::log::is_buffered() {
  emulate -L zsh
  (( ${_zlog_config[buffered]:-0} ))
}


###############################################################################
# FORMATTING SYSTEM
###############################################################################

###
# Format log message as JSON
# Supports context fields as key-value pairs
#
# Usage: __z::log::format_json <level> <message> [context_key context_val ...]
#
# Arguments:
#   level - Log level (0-3)
#   message - Log message
#   ... - Optional key-value pairs (must be even number of args)
#
# Output: Sets REPLY to the JSON string
###
__z::log::format_json() {
  emulate -L zsh
  setopt localoptions extended_glob

  if (( $# < 2 )); then
    REPLY=""
    return 1
  fi

  local level="${1-}"
  local message="${2-}"
  shift 2

  # Truncate message if needed
  __z::log::truncate_message "$message"
  message="$REPLY"

  # Update timestamp
  __z::log::update_timestamp

  # Get metadata using REPLY pattern (no subshells)
  __z::log::level_name "$level"
  local level_name="$REPLY"

  __z::sys::hostname
  local hostname="$REPLY"

  __z::sys::pid
  local pid="$REPLY"

  __z::sys::username
  local username="$REPLY"

  # Escape components using REPLY pattern
  __z::json::escape "$message"
  local escaped_message="$REPLY"

  __z::json::escape "$hostname"
  local escaped_hostname="$REPLY"

  __z::json::escape "$username"
  local escaped_username="$REPLY"

  __z::json::escape "$level_name"
  local escaped_level="$REPLY"

  # Build JSON object efficiently
  local json_output="{"
  json_output+="\"timestamp\":\"${_zlog_timestamp_cache[iso]}\","
  json_output+="\"level\":\"${escaped_level}\","
  json_output+="\"message\":\"${escaped_message}\","
  json_output+="\"hostname\":\"${escaped_hostname}\","
  json_output+="\"pid\":${pid},"
  json_output+="\"user\":\"${escaped_username}\""

  # Add context fields if provided (key-value pairs)
  if (( $# > 0 )); then
    # Validate even number of arguments
    if (( $# % 2 != 0 )); then
      __z::log::debug_internal "Odd number of context arguments ($#), ignoring last"
      # Remove last argument
      set -- "${@[1,-2]}"
    fi

    local key value escaped_key escaped_value
    while (( $# >= 2 )); do
      key="$1"
      value="$2"
      shift 2

      # Skip empty keys
      if [[ -z "$key" ]]; then
        __z::log::debug_internal "Skipping empty context key"
        continue
      fi

      # Validate key format and avoid reserved keys
      if ! __z::log::validate_context_key "$key"; then
        __z::log::debug_internal "Skipping invalid context key: $key"
        continue
      fi

      __z::json::escape "$key"
      escaped_key="$REPLY"

      __z::json::escape "$value"
      escaped_value="$REPLY"

      json_output+=",\"${escaped_key}\":\"${escaped_value}\""
    done
  fi

  # Close JSON object
  json_output+="}"

  REPLY="$json_output"

  return 0
}

###
# Format log message as human-readable text
# Colorized when output to terminal
#
# Usage: __z::log::format_text <level> <message> [context_key context_val ...]
#
# Arguments:
#   level - Log level (0-3)
#   message - Log message
#   ... - Optional key-value pairs (must be even number of args)
#
# Output: Sets REPLY to the formatted text
###
__z::log::format_text() {
  emulate -L zsh
  setopt localoptions

  if (( $# < 2 )); then
    REPLY=""
    return 1
  fi

  local level="${1-}"
  local message="${2-}"
  shift 2

  # Truncate message if needed
  __z::log::truncate_message "$message"
  message="$REPLY"

  # Ensure colors are initialized
  (( _zlog_color_cache[initialized] )) || __z::log::init_colors

  # Update timestamp
  __z::log::update_timestamp

  # Get metadata using REPLY pattern
  __z::log::level_name "$level"
  local level_name="$REPLY"

  __z::sys::pid
  local pid="$REPLY"

  # Determine color and display based on level
  local level_color
  case "$level" in
    ${_ZLOG_LEVEL_ERROR})
      level_color="error"
      ;;
    ${_ZLOG_LEVEL_WARN})
      level_color="warn"
      ;;
    ${_ZLOG_LEVEL_INFO})
      level_color="info"
      ;;
    ${_ZLOG_LEVEL_DEBUG})
      level_color="debug"
      ;;
    *)
      level_color="white"
      ;;
  esac

  # Build level display with color and padding
  z::log::colorize "$level_color" "$level_name"
  local colored_level="$REPLY"
  local level_display="${_zlog_colors[bold]}${colored_level}${_zlog_colors[reset]}"

  # Pad level name to 5 characters for alignment
  local padding=""
  local level_len=${#level_name}
  if (( level_len < 5 )); then
    __z::str::repeat " " $((5 - level_len))
    padding="$REPLY"
  fi
  level_display="${level_display}${padding}"

  # Build base message
  local output=""
  output+="${_zlog_colors[dim]}${_zlog_timestamp_cache[formatted]}${_zlog_colors[reset]}"
  output+=" [${level_display}]"
  output+=" ${_zlog_colors[dim]}(${pid})${_zlog_colors[reset]}"
  output+=" ${message}"

  # Add context fields if provided
  if (( $# > 0 )); then
    # Validate even number of arguments
    if (( $# % 2 != 0 )); then
      __z::log::debug_internal "Odd number of context arguments ($#), ignoring last"
      set -- "${@[1,-2]}"
    fi

    local -a context_parts=()
    local key value

    while (( $# >= 2 )); do
      key="$1"
      value="$2"
      shift 2

      # Skip empty keys
      if [[ -z "$key" ]]; then
        __z::log::debug_internal "Skipping empty context key"
        continue
      fi

      # Validate key format and avoid reserved keys
      if ! __z::log::validate_context_key "$key"; then
        __z::log::debug_internal "Skipping invalid context key: $key"
        continue
      fi

      # Format: key=value with colors
      local formatted_key="${_zlog_colors[dim]}${key}${_zlog_colors[reset]}"
      local formatted_value="${_zlog_colors[cyan]}${value}${_zlog_colors[reset]}"
      context_parts+=("${formatted_key}=${formatted_value}")
    done

    if (( ${#context_parts} > 0 )); then
      local IFS=" "
      output+=" ${_zlog_colors[dim]}|${_zlog_colors[reset]} ${context_parts[*]}"
    fi
  fi

  REPLY="$output"

  return 0
}

###
# Format message according to current configuration
# Dispatches to JSON or text formatter
#
# Usage: __z::log::format <level> <message> [context_key context_val ...]
#
# Output: Prints formatted message to stdout
###
__z::log::format() {
  emulate -L zsh
  setopt localoptions no_unset

  if (( $# < 2 )); then
    REPLY=""
    return 1
  fi

  local level="$1"
  local message="$2"
  shift 2

  case "${_zlog_config[format]}" in
    json)
      __z::log::format_json "$level" "$message" "$@"
      ;;
    text|*)
      __z::log::format_text "$level" "$message" "$@"
      ;;
  esac

  return $?
}

###
# Validate context key
# Usage: if __z::log::validate_context_key "my_key"; then ...; fi
# Returns: 0 if valid, 1 if invalid
###
__z::log::validate_context_key() {
  emulate -L zsh
  local key="${1-}"

  # Empty key
  [[ -z "$key" ]] && return 1

  # Must be alphanumeric, underscore, or hyphen
  [[ "$key" =~ '^[a-zA-Z0-9_-]+$' ]] || return 1

  # Must start with letter or underscore (not number or hyphen)
  [[ "$key" =~ '^[a-zA-Z_]' ]] || return 1

  # Reserved keys (JSON standard fields)
  case "$key" in
    timestamp|level|message|hostname|pid|user)
      return 1
      ;;
  esac

  return 0
}

###
# Sanitize context key (make it valid)
# Usage: __z::log::sanitize_context_key "my-invalid-key!"
#        local clean_key="$REPLY"
#
# Output: Sets REPLY with sanitized key
###
__z::log::sanitize_context_key() {
  emulate -L zsh
  setopt localoptions extended_glob

  local key="${1-}"

  # Remove invalid characters
  key="${key//[^a-zA-Z0-9_-]/}"

  # Ensure starts with letter or underscore
  if [[ "$key" =~ '^[0-9-]' ]]; then
    key="_${key}"
  fi

  # Handle empty result
  if [[ -z "$key" ]]; then
    key="field"
  fi

  # Avoid reserved keys
  case "$key" in
    timestamp|level|message|hostname|pid|user)
      key="${key}_custom"
      ;;
  esac

  REPLY="$key"
  return 0
}


###############################################################################
# CORE LOGGING ENGINE
###############################################################################

###
# Main logging engine with proper error handling and performance optimization
#
# Usage: __z::log::engine <level> <message> [context_key context_val ...]
#
# Arguments:
#   level - Log level (0-3, validated)
#   message - Log message (required, can be empty string)
#   ... - Optional key-value pairs for context
#
# Returns:
#   0 - Success
#   1 - Recursion depth exceeded
#   2 - Invalid level
#   3 - Format failed
#   4 - Write failed (non-fatal, logged to stderr)
#
# Performance: ~100-200μs per call (cached), ~500μs (uncached)
###
###############################################################################
# CORE LOGGING ENGINE
###############################################################################

__z::log::engine() {
  emulate -L zsh
  setopt localoptions no_unset

  if (( $# < 2 )); then
    print -r -u2 -- "zlog: engine requires level and message"
    return 2
  fi

  # Recursion protection
  local max_depth="${_zlog_config[max_depth]:-5}"
  local current_depth="${_zlog_state[depth]:-0}"

  if (( current_depth >= max_depth )); then
    print -r -u2 -- "zlog: Maximum recursion depth ($max_depth) exceeded at depth $current_depth"
    print -r -u2 -- "      This usually indicates a logging loop. Check your log handlers."
    return 1
  fi

  _zlog_state[depth]=$((current_depth + 1))

  local level="${1-}"
  local message="${2-}"
  shift 2

  # Validate level - restore depth on error
  if [[ -z "$level" ]]; then
    print -r -u2 -- "zlog: Log level cannot be empty"
    _zlog_state[depth]=$current_depth
    return 2
  fi

  if [[ ! "$level" =~ ${_zlog_patterns[number]} ]]; then
    print -r -u2 -- "zlog: Invalid log level: '$level' (must be numeric 0-3)"
    _zlog_state[depth]=$current_depth
    return 2
  fi

  if (( level < 0 || level > 3 )); then
    print -r -u2 -- "zlog: Log level out of range: $level (must be 0-3)"
    print -r -u2 -- "      0=ERROR, 1=WARN, 2=INFO, 3=DEBUG"
    _zlog_state[depth]=$current_depth
    return 2
  fi

  # Early exit optimization
  if (( ! _zlog_state[any_logging_enabled] )); then
    _zlog_state[depth]=$current_depth
    return 0
  fi

  # Get console and file levels
  local console_level="${_zlog_config[level]:-2}"
  local file_level="${_zlog_config[file_level]:--1}"
  (( file_level == -1 )) && file_level=$console_level

  # Calculate output targets
  local -i should_console=$(( level <= console_level ))
  local -i should_file=$(( _zlog_state[file_enabled] && level <= file_level ))

  # Early exit if nothing to do
  if (( !should_console && !should_file )); then
    _zlog_state[depth]=$current_depth
    return 0
  fi

  # Format message with error handling. Do not use command substitution here:
  # it would run the formatter in a subshell and discard cache updates.
  local formatted
  __z::log::format "$level" "$message" "$@"
  local format_status=$?

  if (( format_status != 0 )); then
    # Fallback formatting on error
    print -r -u2 -- "zlog: Format failed, using fallback"

    local timestamp=$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || print -r -- "UNKNOWN")
    local level_name="${_ZLOG_LEVEL_NAMES[$level]:-UNKNOWN}"
    formatted="$timestamp [$level_name] ($$) [FORMAT_ERROR] $message"
  else
    formatted="$REPLY"
  fi

  # Track statistics
  (( _zlog_stats[messages_logged]++ ))

  # Output to console
  if (( should_console )); then
    if ! print -r -u2 -- "$formatted"; then
      (( _zlog_stats[errors_encountered]++ ))
      print -r -u2 -- "zlog: stderr write failed: $formatted" 2>/dev/null || true
    fi
  fi

  # Output to file
  if (( should_file )); then
    local write_status=0

    if (( ${_zlog_config[buffered]:-0} )); then
      __z::log::buffer_add "$formatted" "$level"
      write_status=$?
    else
      __z::log::write_file "$formatted"
      write_status=$?
    fi

    if (( write_status != 0 )); then
      (( _zlog_stats[errors_encountered]++ ))
      if (( _zlog_stats[errors_encountered] <= 5 )); then
        print -r -u2 -- "zlog: File write failed (status: $write_status, error count: ${_zlog_stats[errors_encountered]})"
      elif (( _zlog_stats[errors_encountered] == 6 )); then
        print -r -u2 -- "zlog: File write errors continue, suppressing further error messages"
      fi
    fi
  fi

  # ✅ Always restore depth before returning
  _zlog_state[depth]=$current_depth
  return 0
}
###############################################################################
# OPTIMIZED FAST ENGINE (Performance Mode)
###############################################################################

###
# Fast path engine - bypasses some safety checks for maximum performance
# Only use when performance is critical and inputs are trusted
#
# Optimizations:
#   - No recursion checking
#   - No level validation
#   - No error handling
#   - Inline formatting for simple cases
#   - Direct buffer manipulation
#
# Performance: ~50-80μs per call (3-4x faster than normal engine)
###
__z::log::engine_fast() {
  emulate -L zsh
  setopt localoptions no_unset

  if (( $# < 2 )); then
    return 1
  fi

  local level="${1-}"
  local message="${2-}"
  shift 2

  # Fast level check (most common case: filtered out)
  local console_level="${_zlog_config[level]:-2}"
  local file_level="${_zlog_config[file_level]:--1}"
  (( file_level == -1 )) && file_level=$console_level

  # Early exit if both console and file filter this out
  if (( level > console_level && level > file_level )); then
    return 0
  fi

  local formatted
  if (( $# == 0 )); then
    __z::log::format_simple "$level" "$message"
    formatted="$REPLY"
  else
    __z::log::format "$level" "$message" "$@" || return 1
    formatted="$REPLY"
  fi

  # Output to console if appropriate
  (( level <= console_level )) && print -r -u2 -- "$formatted"

  # Output to file if appropriate
  if (( level <= file_level && _zlog_state[file_enabled] )); then
    if (( ${_zlog_config[buffered]:-0} )); then
      _zlog_buffer+=("$formatted")

      # Auto-flush on errors or when buffer full
      if (( level == 0 || ${#_zlog_buffer} >= ${_zlog_config[buffer_max]:-50} )); then
        __z::log::flush_fast
      fi
    else
      __z::log::fast_write "$formatted"
    fi
  fi

  return 0
}

###############################################################################
# PUBLIC API - CORE LOGGING FUNCTIONS
###############################################################################

###
# Log error message
# Always outputs to stderr (if error level is enabled)
#
# Usage:
#   z::log::error "message" [key val ...]
#   z::log::error "Database connection failed" "host" "localhost" "port" "5432"
#
# Arguments:
#   message - Error message (required)
#   ... - Optional key-value pairs for context
#
# Returns: 0 always (errors should not stop execution)
###
z::log::error() {
  emulate -L zsh
  setopt localoptions no_unset

  if (( $# < 1 )); then
    print -r -u2 -- "zlog: error() requires at least a message"
    return 1
  fi

  if (( ! _zlog_state[any_logging_enabled] )); then
    return 0
  fi

  # Lazy evaluation: early exit if level too high
  local console_level="${_zlog_config[level]:-2}"
  local file_level="${_zlog_config[file_level]:--1}"
  (( file_level == -1 )) && file_level=$console_level

  # Error is level 0, check if either console or file will log it
  if (( ${_ZLOG_LEVEL_ERROR:-0} > console_level && ${_ZLOG_LEVEL_ERROR:-0} > file_level )); then
    return 0
  fi

  __z::log::engine "${_ZLOG_LEVEL_ERROR}" "$@"
}

###
# Log warning message
#
# Usage:
#   z::log::warn "message" [key val ...]
#   z::log::warn "Disk space low" "available" "10GB" "threshold" "20GB"
#
# Arguments:
#   message - Warning message (required)
#   ... - Optional key-value pairs for context
#
# Returns: 0 always
###
z::log::warn() {
  emulate -L zsh
  setopt localoptions no_unset

  if (( $# < 1 )); then
    print -r -u2 -- "zlog: warn() requires at least a message"
    return 1
  fi

  if (( ! _zlog_state[any_logging_enabled] )); then
    return 0
  fi

  # Lazy evaluation: early exit if level too high
  local console_level="${_zlog_config[level]:-2}"
  local file_level="${_zlog_config[file_level]:--1}"
  (( file_level == -1 )) && file_level=$console_level

  if (( ${_ZLOG_LEVEL_WARN:-1} > console_level && ${_ZLOG_LEVEL_WARN:-1} > file_level )); then
    return 0
  fi

  __z::log::engine "${_ZLOG_LEVEL_WARN}" "$@"
}

###
# Log info message
#
# Usage:
#   z::log::info "message" [key val ...]
#   z::log::info "Server started" "port" "8080" "env" "production"
#
# Arguments:
#   message - Info message (required)
#   ... - Optional key-value pairs for context
#
# Returns: 0 always
###
z::log::info() {
  emulate -L zsh
  setopt localoptions no_unset

  if (( $# < 1 )); then
    print -r -u2 -- "zlog: info() requires at least a message"
    return 1
  fi

  if (( ! _zlog_state[any_logging_enabled] )); then
    return 0
  fi

  # Lazy evaluation: early exit if level too high
  local console_level="${_zlog_config[level]:-2}"
  local file_level="${_zlog_config[file_level]:--1}"
  (( file_level == -1 )) && file_level=$console_level

  if (( ${_ZLOG_LEVEL_INFO:-2} > console_level && ${_ZLOG_LEVEL_INFO:-2} > file_level )); then
    return 0
  fi

  __z::log::engine "${_ZLOG_LEVEL_INFO}" "$@"
}

