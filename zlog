###
# Set output format
# Usage: z::log::set_format <format>
#
# Arguments:
#   format - "text" or "json"
###
z::log::set_format() {
  emulate -L zsh
  local format="$1"

  # Validate input
  if [[ -z "$format" ]]; then
    print -r -u2 -- "zlog: Format cannot be empty"
    return 1
  fi

  # Normalize to lowercase
  format="${format:l}"

  case "$format" in
    text|json)
      _zlog_config[format]="$format"
      __z::log::debug_internal "Output format set to: $format"
      return 0
      ;;
    *)
      print -r -u2 -- "zlog: Invalid format: $format (use 'text' or 'json')"
      return 1
      ;;
  esac
}

###
# Set log level for console output
# Usage: z::log::set_level <level>
#
# Arguments:
#   level - Level name (error/warn/info/debug) or number (0-3)
###
z::log::set_level() {
  emulate -L zsh
  local level_input="$1"

  # Validate input
  if [[ -z "$level_input" ]]; then
    print -r -u2 -- "zlog: Level cannot be empty"
    return 1
  fi

  # Convert to number
  __z::log::level_number "$level_input"
  local level_status=$?
  local level_num="$REPLY"

  if (( level_status != 0 )); then
    print -r -u2 -- "zlog: Invalid log level: $level_input (use: error, warn, info, debug)"
    return 1
  fi

  _zlog_config[level]=$level_num
  __z::log::update_fast_flags
  __z::log::level_name "$level_num"
  local level_name="$REPLY"
  __z::log::debug_internal "Console log level set to: $level_num ($level_name)"

  return 0
}

###
# Set log level for file output
# Usage: z::log::set_file_level <level>
#
# Arguments:
#   level - Level name (error/warn/info/debug), number (0-3), or -1 (follow console)
###
z::log::set_file_level() {
  emulate -L zsh
  local level_input="$1"

  # Validate input
  if [[ -z "$level_input" ]]; then
    print -r -u2 -- "zlog: Level cannot be empty"
    return 1
  fi

  # Special case: -1 or "console" means follow console level
  if [[ "$level_input" == "-1" ]] || [[ "$level_input" == "console" ]]; then
    _zlog_config[file_level]=-1
    __z::log::update_fast_flags
    __z::log::debug_internal "File log level set to follow console level"
    return 0
  fi

  # Convert to number
  __z::log::level_number "$level_input"
  local level_status=$?
  local level_num="$REPLY"

  if (( level_status != 0 )); then
    print -r -u2 -- "zlog: Invalid file log level: $level_input"
    return 1
  fi

  _zlog_config[file_level]=$level_num
  __z::log::update_fast_flags
  __z::log::level_name "$level_num"
  local level_name="$REPLY"
  __z::log::debug_internal "File log level set to: $level_num ($level_name)"

  return 0
}

###
# Set log file path
# Usage: z::log::set_file <path>
#
# Arguments:
#   path - Log file path (empty string disables file logging)
###
z::log::set_file() {
  emulate -L zsh
  local filepath="${1-}"
  local old_file="${_zlog_config[file]}"

  # Flush any pending messages to old file
  if [[ -n "${_zlog_config[file]}" ]] && (( ${_zlog_config[buffered]:-0} )); then
    if ! z::log::flush; then
      print -r -u2 -- "zlog: Failed to flush buffer before changing log file"
      return 1
    fi
  fi

  # Async workers capture the file path at startup.
  # Disable async before switching destinations.
  if [[ "$filepath" != "$old_file" ]] && (( ${+functions[z::log::is_async]} )) && z::log::is_async; then
    z::log::disable_async || {
      print -r -u2 -- "zlog: Failed to disable async before changing log file"
      return 1
    }
  fi

  _zlog_config[file]="$filepath"

  if [[ -z "$filepath" ]]; then
    __z::log::debug_internal "File logging disabled"
  else
    __z::log::debug_internal "Log file set to: $filepath"

    # Reset stat command detection for new file
    _zlog_state[stat_cmd]=""
    _zlog_state[stat_bin]=""
  fi

  # Update fast-path flags so file_enabled reflects the new path
  __z::log::update_fast_flags

  return 0
}

###
# Configure file rotation
# Usage: z::log::set_rotation <enabled> [max_size] [keep_count]
#
# Arguments:
#   enabled - 1 to enable, 0 to disable
#   max_size - Maximum file size (default: 10MB, accepts human-readable like "10MB")
#   keep_count - Number of old files to keep (default: 5)
###
z::log::set_rotation() {
  emulate -L zsh
  local enabled="${1-}"
  local max_size="${2:-10MB}"
  local keep_count="${3:-5}"

  # Validate enabled flag
  if [[ "$enabled" != "0" ]] && [[ "$enabled" != "1" ]]; then
    print -r -u2 -- "zlog: Invalid rotation flag: $enabled (use 0 or 1)"
    return 1
  fi

  # Parse max_size (supports human-readable)
  __z::log::parse_size "$max_size"
  local parse_status=$?
  local size_bytes="$REPLY"

  if (( parse_status != 0 )); then
    print -r -u2 -- "zlog: Invalid max size: $max_size"
    return 1
  fi

  # Validate keep_count
  if [[ ! "$keep_count" =~ '^[0-9]+$' ]]; then
    print -r -u2 -- "zlog: Invalid keep count: $keep_count (must be non-negative integer)"
    return 1
  fi

  _zlog_config[rotate]=$enabled
  _zlog_config[rotate_size]=$size_bytes
  _zlog_config[rotate_keep]=$keep_count

  __z::log::format_size "$size_bytes"
  local size_human="$REPLY"
  __z::log::debug_internal "Rotation configured: enabled=$enabled, max_size=$size_human, keep=$keep_count"

  return 0
}

###
# Quick start helper - configure logging in one call
# Usage: z::log::setup <file> [level] [format]
#
# Arguments:
#   file - Log file path (use "-" for console only)
#   level - Log level (default: info)
#   format - Output format (default: text)
###
z::log::setup() {
  emulate -L zsh
  local file="${1-}"
  local level="${2:-info}"
  local format="${3:-text}"

  # Validate file argument
  if [[ -z "$file" ]]; then
    print -r -u2 -- "zlog: File path required (use '-' for console only)"
    return 1
  fi

  __z::log::level_number "$level" || {
    print -r -u2 -- "zlog: Invalid setup level: $level"
    return 1
  }

  case "${format:l}" in
    text|json) ;;
    *)
      print -r -u2 -- "zlog: Invalid setup format: $format"
      return 1
      ;;
  esac

  # Set file (use empty string for console-only)
  if [[ "$file" == "-" ]]; then
    z::log::set_file ""
  else
    z::log::set_file "$file" || return 1
  fi

  # Set level
  z::log::set_level "$level" || return 1

  # Set format
  z::log::set_format "$format" || return 1

  __z::log::debug_internal "Quick start complete: file=$file, level=$level, format=$format"

  # Log initialization message
  z::log::info "Quick start logging initialized" "file" "$file" "level" "$level"

  return 0
}

###
# Reset logging configuration to defaults
# Usage: z::log::reset
###
z::log::reset() {
  emulate -L zsh

  # Restore original engine before resetting config.
  if (( ${_zlog_config[fast_mode]:-0} )) && (( ${+functions[z::log::disable_performance_mode]} )); then
    z::log::disable_performance_mode
  fi

  # Flush any pending messages
  if ! z::log::flush; then
    print -r -u2 -- "zlog: Failed to flush before reset"
    return 1
  fi

  if (( ${+functions[z::log::is_async]} )) && z::log::is_async; then
    z::log::disable_async || return 1
  fi

  # Reset to defaults
  _zlog_config[level]=2
  _zlog_config[format]="text"
  _zlog_config[file]=""
  _zlog_config[file_level]=-1
  _zlog_config[rotate]=1
  _zlog_config[rotate_size]=10485760
  _zlog_config[rotate_keep]=5
  _zlog_config[rotation_lock_timeout]=5
  _zlog_config[buffered]=0
  _zlog_config[buffer_max]=50
  _zlog_config[max_message_size]=0
  _zlog_config[debug_mode]=0
  _zlog_config[timestamp_cache_enabled]=1
  _zlog_state[depth]=0

  # Clear buffers
  _zlog_buffer=()

  # Clear caches
  _zlog_state[stat_cmd]=""
  _zlog_state[stat_bin]=""
  _zlog_timestamp_cache[epoch]=0
  _zlog_timestamp_cache[formatted]=""
  _zlog_timestamp_cache[iso]=""
  _zlog_timestamp_cache[ms]=""
  _zlog_state[buffer_count]=0

  __z::log::update_fast_flags

  __z::log::debug_internal "Configuration reset to defaults"

  return 0
}

###############################################################################
# ASYNC LOGGING SYSTEM (OPTIONAL)
###############################################################################

# Note: Async logging uses a background process and FIFO for maximum throughput
# This is optional and adds complexity, but can handle very high log volumes

###
# Enable async logging (experimental)
# Creates a background worker process that handles all file I/O
# Usage: z::log::enable_async
###
z::log::enable_async() {
  emulate -L zsh
  setopt localoptions no_unset

  # Check if already enabled
  if [[ -n "${_zlog_state[async_pid]:-}" ]] && kill -0 "${_zlog_state[async_pid]}" 2>/dev/null; then
    z::log::warn "Async logging already enabled"
    return 0
  fi

  # Check if file logging is configured
  if [[ -z "${_zlog_config[file]}" ]]; then
    z::log::error "Cannot enable async logging: no log file configured"
    return 1
  fi

  # Create FIFO in a private directory under TMPDIR.
  local fifo_root="${TMPDIR:-/tmp}"
  fifo_root="${fifo_root%/}"
  local fifo_dir="${fifo_root}/zlog_fifo_$$_${RANDOM}"
  local fifo_path="${fifo_dir}/fifo"

  if ! command mkdir -m 700 "$fifo_dir" 2>/dev/null; then
    z::log::error "Failed to create private directory for async logging"
    return 1
  fi

  if ! mkfifo "$fifo_path" 2>/dev/null; then
    z::log::error "Failed to create FIFO for async logging"
    rmdir "$fifo_dir" 2>/dev/null || true
    return 1
  fi

  _zlog_state[async_fifo]="$fifo_path"

  # Start background worker
  (
    emulate -L zsh
    # Worker process - reads from FIFO and writes to file
    exec <"$fifo_path" || exit 1

    local log_file="${_zlog_config[file]}"

    while IFS= read -r line; do
      # Check for shutdown signal
      [[ "$line" == "__ASYNC_SHUTDOWN__" ]] && break

      # Write to log file
      print -r -- "$line" >> "$log_file"
    done

    # Cleanup
    rm -f -- "$fifo_path"
    rmdir -- "$fifo_dir" 2>/dev/null || true
  ) &

  local worker_pid=$!
  _zlog_state[async_pid]=$worker_pid

  # Open FIFO for writing
  local fifo_fd
  if ! exec {fifo_fd}>"$fifo_path"; then
    kill "$worker_pid" 2>/dev/null || true
    wait "$worker_pid" 2>/dev/null || true
    rm -f -- "$fifo_path"
    rmdir -- "$fifo_dir" 2>/dev/null || true
    _zlog_state[async_pid]=""
    _zlog_state[async_fd]=-1
    _zlog_state[async_fifo]=""
    z::log::error "Failed to open FIFO for async logging"
    return 1
  fi
  _zlog_state[async_fd]=$fifo_fd

  z::log::info "Async logging enabled" "worker_pid" "$worker_pid"

  return 0
}

###
# Disable async logging
# Shuts down background worker gracefully
# Usage: z::log::disable_async
###
z::log::disable_async() {
  emulate -L zsh

  # Check if async is enabled
  local async_pid="${_zlog_state[async_pid]:-}"
  if [[ -z "$async_pid" ]]; then
    return 0
  fi

  # Send shutdown signal
  local async_fd="${_zlog_state[async_fd]:--1}"
  if [[ "$async_fd" =~ '^[0-9]+$' ]] && (( async_fd >= 0 )); then
    print -u "$async_fd" -r -- "__ASYNC_SHUTDOWN__" 2>/dev/null || true
    exec {async_fd}>&- 2>/dev/null || true
  fi

  # Wait for worker to finish (with timeout)
  local timeout=5
  local elapsed=0

  while kill -0 "$async_pid" 2>/dev/null; do
    sleep 0.1
    elapsed=$(( elapsed + 1 ))

    if (( elapsed > timeout * 10 )); then
      # Force kill if timeout
      kill -9 "$async_pid" 2>/dev/null
      break
    fi
  done

  wait "$async_pid" 2>/dev/null || true

  # Cleanup
  _zlog_state[async_pid]=""
  _zlog_state[async_fd]=-1
  [[ -n "${_zlog_state[async_fifo]:-}" ]] && rm -f -- "${_zlog_state[async_fifo]}" 2>/dev/null || true
  _zlog_state[async_fifo]=""

  return 0
}

###
# Check if async logging is enabled
# Returns 0 (true) if async is active
# Usage: if z::log::is_async; then ...; fi
###
z::log::is_async() {
  emulate -L zsh

  [[ -n "${_zlog_state[async_pid]:-}" ]] && \
    kill -0 "${_zlog_state[async_pid]}" 2>/dev/null
}

###
# Write to async FIFO (internal)
# Usage: __z::log::write_async "message"
###
__z::log::write_async() {
  emulate -L zsh
  local message="${1-}"

  local async_fd="${_zlog_state[async_fd]:--1}"
  if [[ "$async_fd" =~ '^[0-9]+$' ]] && (( async_fd >= 0 )); then
    print -u "$async_fd" -r -- "$message"
    return $?
  fi

  return 1
}
###############################################################################
# OPTIMIZED FOR PERFORMANCE AND SPEED ROUTE IMPLEMENTATIONS
###############################################################################

###
# Fast path for simple logging (bypasses most overhead)
# Usage: __z::log::fast_write "message"
###
__z::log::fast_write() {
  emulate -L zsh
  local message="${1-}"
  local logfile="${_zlog_config[file]}"

  [[ -z "$logfile" ]] && return 0

  __z::log::ensure_log_dir "$logfile" || return 1

  # Direct write without rotation check in performance mode.
  print -r -- "$message" >> "$logfile" 2>/dev/null
}

###
# Optimized engine for high-performance logging
# Caches more aggressively and skips unnecessary work
###
__z::log::engine_fast() {
  emulate -L zsh
  setopt localoptions

  if (( $# < 2 )); then
    return 1
  fi

  local level="${1-}"
  local message="${2-}"
  shift 2

  # Fast level check (most common case: filtered out)
  local console_level="${_zlog_config[level]:-2}"
  if (( level > console_level )); then
    local file_level="${_zlog_config[file_level]:--1}"
    (( file_level == -1 )) && file_level=$console_level

    # Early exit if both console and file filter this out
    if (( level > file_level )); then
      return 0
    fi
  fi

  # Use cached formatting if no context provided
  local formatted
  if (( $# == 0 )); then
    __z::log::format_simple "$level" "$message"
    formatted="$REPLY"
  else
    __z::log::format "$level" "$message" "$@" || return 1
    formatted="$REPLY"
  fi

  # Output to console if appropriate
  if (( level <= console_level )); then
    print -r -u2 -- "$formatted"
  fi

  # Output to file if appropriate
  if [[ -n "${_zlog_config[file]}" ]]; then
    local file_level="${_zlog_config[file_level]:--1}"
    (( file_level == -1 )) && file_level=$console_level

    if (( level <= file_level )); then
      if (( ${_zlog_config[buffered]:-0} )); then
        _zlog_buffer+=("$formatted")

        # Auto-flush on errors or when buffer full
        if (( level == 0 || ${#_zlog_buffer} >= ${_zlog_config[buffer_max]:-50} )); then
          __z::log::flush_fast
        fi
      else
        __z::log::fast_write "$formatted"
      fi
    fi
  fi

  return 0
}

###
# Simplified formatter for messages without context (90% of cases)
# Sets REPLY with formatted message
###
__z::log::format_simple() {
  emulate -L zsh
  local level="${1-}"
  local message="${2-}"

  __z::log::truncate_message "$message"
  message="$REPLY"

  # Update timestamp only if needed
  local current_epoch=${EPOCHSECONDS}
  if (( current_epoch != _zlog_timestamp_cache[epoch] )); then
    __z::log::update_timestamp
  fi

  # Use cached level name
  local level_name="${_ZLOG_LEVEL_NAMES[$level]:-UNKNOWN}"

  # Fast text format (most common)
  if [[ "${_zlog_config[format]}" == "text" ]]; then
    # Build without colors if not a TTY (faster)
    if [[ ! -t 2 ]]; then
      REPLY="${_zlog_timestamp_cache[formatted]} [${level_name}] (${_zlog_sys_cache[pid]:-$$}) ${message}"
    else
      (( _zlog_color_cache[initialized] )) || __z::log::init_colors

      # With colors
      local level_color
      case "$level" in
        0) level_color="${_zlog_colors[error]}" ;;
        1) level_color="${_zlog_colors[warn]}" ;;
        2) level_color="${_zlog_colors[info]}" ;;
        3) level_color="${_zlog_colors[debug]}" ;;
        *) level_color="" ;;
      esac

      local level_display="${_zlog_colors[bold]}${level_color}${level_name}${_zlog_colors[reset]}"

      # Pad level name
      local padding=""
      local level_len=${#level_name}
      if (( level_len < 5 )); then
        padding="${(r:$((5-level_len)):: :)}"
      fi

      REPLY="${_zlog_colors[dim]}${_zlog_timestamp_cache[formatted]}${_zlog_colors[reset]} [${level_display}${padding}] ${_zlog_colors[dim]}(${_zlog_sys_cache[pid]:-$$})${_zlog_colors[reset]} ${message}"
    fi
  else
    # JSON format
    __z::json::escape "$message"
    local escaped_message="$REPLY"

    REPLY="{\"timestamp\":\"${_zlog_timestamp_cache[iso]}\",\"level\":\"${level_name}\",\"message\":\"${escaped_message}\",\"pid\":${_zlog_sys_cache[pid]:-$$}}"
  fi

  return 0
}

###
# Fast flush without rotation checks (for buffered mode)
###
__z::log::flush_fast() {
  emulate -L zsh
  setopt localoptions

  (( ${#_zlog_buffer} == 0 )) && return 0

  local logfile="${_zlog_config[file]}"

  if [[ -z "$logfile" ]]; then
    _zlog_buffer=()
    _zlog_state[buffer_count]=0
    return 0
  fi

  __z::log::ensure_log_dir "$logfile" || return 1

  # Bulk write without rotation check
  if printf '%s\n' "${_zlog_buffer[@]}" >> "$logfile" 2>/dev/null; then
    _zlog_buffer=()
    _zlog_state[buffer_count]=0
    (( _zlog_stats[buffer_flushes]++ ))
    return 0
  else
    return 1
  fi
}

###
# Enable performance mode (uses optimized code paths)
###
z::log::enable_performance_mode() {
  emulate -L zsh

  if (( ${_zlog_config[fast_mode]:-0} )); then
    return 0
  fi

  # Replace engine with fast version
  if (( ! ${+functions[__z::log::engine_original]} )); then
  functions[__z::log::engine_original]="${functions[__z::log::engine]}"
  fi
  functions[__z::log::engine]="${functions[__z::log::engine_fast]}"

  # Disable timestamp cache updates (use stale timestamps for 1 second)
  _zlog_config[timestamp_cache_enabled]=1

  # Disable internal debugging
  _zlog_config[debug_mode]=0

  # Disable rotation checks in buffered mode
  _zlog_config[fast_mode]=1

  __z::log::debug_internal "Performance mode enabled"

  return 0
}

###
# Disable performance mode (restore normal behavior)
###
z::log::disable_performance_mode() {
  emulate -L zsh

  if (( ! ${_zlog_config[fast_mode]:-0} )); then
    return 0
  fi

  # Restore original engine
  if (( ${+functions[__z::log::engine_original]} )); then
    functions[__z::log::engine]="${functions[__z::log::engine_original]}"
    unfunction __z::log::engine_original
  fi

  _zlog_config[fast_mode]=0

  __z::log::debug_internal "Performance mode disabled"

  return 0
}


###############################################################################
# INITIALIZATION
###############################################################################

# Initialize the framework (idempotent)
if (( ! ${+_zlog_finalized} )); then
  typeset -gi _zlog_finalized=0
fi

if (( ! _zlog_finalized )); then
  __z::log::validate_globals
  __z::log::update_timestamp
  __z::log::update_fast_flags

  # Initialize cache on first load
  if [[ -z "${_zlog_sys_cache[hostname]}" ]]; then
    _zlog_sys_cache[hostname]="${HOST:-${HOSTNAME:-unknown}}"
  fi

  if [[ -z "${_zlog_sys_cache[username]}" ]]; then
    _zlog_sys_cache[username]="${USER:-${USERNAME:-unknown}}"
  fi

  # Set default log level if not already set
  if [[ -z "${_zlog_config[level]}" ]]; then
    _zlog_config[level]=${_ZLOG_LEVEL_INFO}
  fi

  _zlog_finalized=1

fi
