###
# Get current console log level as string
# Usage: level=$(z::log::get_level)
###
z::log::get_level() {
  emulate -L zsh
  local level="${_zlog_config[level]:-2}"
  __z::log::level_name "$level"
  print -r -- "$REPLY"
  return 0
}

###
# Get current file log level as string
# Usage: level=$(z::log::get_file_level)
###
z::log::get_file_level() {
  emulate -L zsh
  local file_level="${_zlog_config[file_level]:--1}"

  if (( file_level == -1 )); then
    print -r -- "console"
  else
    __z::log::level_name "$file_level"
    print -r -- "$REPLY"
  fi

  return 0
}

###
# Get current output format
# Usage: format=$(z::log::get_format)
###
z::log::get_format() {
  emulate -L zsh
  print -r -- "${_zlog_config[format]}"
  return 0
}

###
# Get current log file path
# Usage: file=$(z::log::get_file)
###
z::log::get_file() {
  emulate -L zsh
  print -r -- "${_zlog_config[file]}"
  return 0
}

###
# Get current configuration as human-readable output
# Usage: z::log::show_config
###
z::log::show_config() {
  emulate -L zsh

  local console_level="${_zlog_config[level]:-2}"
  __z::log::level_name "$console_level"
  local console_level_name="$REPLY"

  local file_level="${_zlog_config[file_level]:--1}"
  local file_level_name
  if (( file_level == -1 )); then
    file_level_name="FOLLOW_CONSOLE"
  else
    __z::log::level_name "$file_level"
    file_level_name="$REPLY"
  fi

  local color_mode="${_zlog_color_cache[mode]}"
  local hook_method="${_zlog_config[exit_hook_method]:-none}"

  print -r -- "╔════════════════════════════════════════════════════════════════╗"
  print -r -- "║                    ZLOG Configuration                          ║"
  print -r -- "╠════════════════════════════════════════════════════════════════╣"
  print -r -- "║ Console Level:      $(printf '%-40s' "$console_level_name ($console_level)")   ║"
  print -r -- "║ File Level:         $(printf '%-40s' "$file_level_name ($file_level)")   ║"
  print -r -- "║ Format:             $(printf '%-40s' "${_zlog_config[format]:-text}")   ║"
  print -r -- "║ Log File:           $(printf '%-40s' "${_zlog_config[file]:-<none>}")   ║"
  print -r -- "╠════════════════════════════════════════════════════════════════╣"
  print -r -- "║ Rotation:           $(printf '%-40s' "$( (( ${_zlog_config[rotate]:-1} )) && echo 'enabled' || echo 'disabled' )")   ║"
  __z::log::format_size "${_zlog_config[rotate_size]:-0}"
  print -r -- "║ Rotation Size:      $(printf '%-40s' "$REPLY")   ║"
  print -r -- "║ Rotation Keep:      $(printf '%-40s' "${_zlog_config[rotate_keep]:-5} files")   ║"
  print -r -- "║ Lock Timeout:       $(printf '%-40s' "${_zlog_config[rotation_lock_timeout]:-5}s")   ║"
  print -r -- "╠════════════════════════════════════════════════════════════════╣"
  print -r -- "║ Buffering:          $(printf '%-40s' "$( (( ${_zlog_config[buffered]:-0} )) && echo 'enabled' || echo 'disabled' )")   ║"
  print -r -- "║ Buffer Max:         $(printf '%-40s' "${_zlog_config[buffer_max]:-50} messages")   ║"
  print -r -- "║ Buffer Current:     $(printf '%-40s' "${#_zlog_buffer} messages")   ║"
  print -r -- "║ Exit Hook:          $(printf '%-40s' "$hook_method")   ║"
  print -r -- "╠════════════════════════════════════════════════════════════════╣"
  print -r -- "║ Max Message Size:   $(printf '%-40s' "$( (( ${_zlog_config[max_message_size]:-0} == 0 )) && echo 'unlimited' || echo \"$(z::log::get_max_message_size 2>/dev/null || echo 'N/A')\" )")   ║"
  print -r -- "║ Truncate Marker:    $(printf '%-40s' "${_zlog_config[truncate_marker]}")   ║"
  print -r -- "╠════════════════════════════════════════════════════════════════╣"
  print -r -- "║ Color Mode:         $(printf '%-40s' "$color_mode")   ║"
  print -r -- "║ Timestamp Cache:    $(printf '%-40s' "$( (( ${_zlog_config[timestamp_cache_enabled]:-1} )) && echo 'enabled' || echo 'disabled' )")   ║"
  print -r -- "║ Debug Mode:         $(printf '%-40s' "$( (( ${_zlog_config[debug_mode]:-0} )) && echo 'enabled' || echo 'disabled' )")   ║"
  print -r -- "╠════════════════════════════════════════════════════════════════╣"
  print -r -- "║ Active Contexts:    $(printf '%-40s' "${#_zlog_contexts}")   ║"
  print -r -- "║ Active Timers:      $(printf '%-40s' "${#_zlog_benchmark_timers}")   ║"
