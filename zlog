if [[ -z ${ZSH_VERSION-} ]]; then
  print -r -u2 -- "ERROR: This framework requires Zsh"
  return 1 2>/dev/null || exit 1
fi

emulate zsh
setopt typeset_silent

if ! zmodload zsh/datetime 2>/dev/null; then
  print -r -u2 -- "zlog: zsh/datetime module is required"
  return 1 2>/dev/null || exit 1
fi

###############################################################################
# INITIALIZATION GUARD
###############################################################################

if (( ! ${+_zlog_initialized} )); then
  typeset -gi _zlog_initialized=0
fi

###############################################################################
# CONSTANTS (Readonly)
###############################################################################

typeset -gr _ZLOG_VERSION="1.0.0"

# Log levels
typeset -gri _ZLOG_LEVEL_ERROR=0
typeset -gri _ZLOG_LEVEL_WARN=1
typeset -gri _ZLOG_LEVEL_INFO=2
typeset -gri _ZLOG_LEVEL_DEBUG=3

# Level name mappings (readonly)
typeset -grA _ZLOG_LEVEL_NAMES=(
  [0]="ERROR"
  [1]="WARN"
  [2]="INFO"
  [3]="DEBUG"
)

# Reverse lookup: name -> number (case-insensitive)
typeset -grA _ZLOG_LEVEL_VALUES=(
  [ERROR]=0 [error]=0
  [WARN]=1  [warn]=1
  [INFO]=2  [info]=2
  [DEBUG]=3 [debug]=3
)

# Limits and defaults
typeset -gri _ZLOG_MIN_ROTATE_SIZE=1024              # 1KB
typeset -gri _ZLOG_MAX_ROTATE_SIZE=1073741824        # 1GB
typeset -gri _ZLOG_MIN_BUFFER_SIZE=1
typeset -gri _ZLOG_MAX_BUFFER_SIZE=10000
typeset -gri _ZLOG_MAX_CONTEXTS=100
typeset -gri _ZLOG_MAX_TIMERS=50
typeset -gri _ZLOG_MAX_RECURSION_DEPTH=5
typeset -gri _ZLOG_DEFAULT_ROTATION_LOCK_TIMEOUT=5
typeset -gri _ZLOG_DEFAULT_ROTATE_SIZE=10485760      # 10MB
typeset -gri _ZLOG_DEFAULT_ROTATE_KEEP=5

###############################################################################
# USER CONFIGURATION
###############################################################################

if (( ! ${+_zlog_config} )); then
  typeset -gA _zlog_config=(
    # Core settings
    [level]=$_ZLOG_LEVEL_DEBUG
    [file_level]=-1
    [format]="text"
    [file]=""

    # Rotation
    [rotate]=1
    [rotate_size]=$_ZLOG_DEFAULT_ROTATE_SIZE
    [rotate_keep]=$_ZLOG_DEFAULT_ROTATE_KEEP
    [rotation_lock_timeout]=$_ZLOG_DEFAULT_ROTATION_LOCK_TIMEOUT

    # Performance
    [buffered]=0
    [buffer_max]=50
    [fast_mode]=0

    # Message handling
    [max_message_size]=0
    [truncate_marker]="... [TRUNCATED]"
    [max_depth]=$_ZLOG_MAX_RECURSION_DEPTH

    # Cache
    [timestamp_cache_enabled]=1

    # Debug
    [debug_mode]=0

    # Exit hook tracking
    [exit_hook_method]=""
  )
fi

###############################################################################
# RUNTIME STATE
###############################################################################

if (( ! ${+_zlog_state} )); then
  typeset -gA _zlog_state=(
    # File handling
    [fd]=-1
    [stat_cmd]=""

    # Async worker
    [async_pid]=""
    [async_fd]=-1
    [async_fifo]=""

    # Recursion protection
    [depth]=0

    # Buffer state
    [buffer_count]=0

    # Cleanup
    [cleanup_registered]=0

    # Fast-path optimization flags
    [console_enabled]=1
    [file_enabled]=0
    [any_logging_enabled]=1

    # Resource tracking
    [context_count]=0
    [timer_count]=0
  )
fi

###############################################################################
# CACHES
###############################################################################

# General cache
if (( ! ${+_zlog_cache} )); then
  typeset -gA _zlog_cache=(
    [strftime_available]=""
  )
fi

# Timestamp cache
if (( ! ${+_zlog_timestamp_cache} )); then
  typeset -gA _zlog_timestamp_cache=(
    [epoch]=0
    [formatted]=""
    [iso]=""
    [ms]=""
    [custom_format]=""
  )
fi

# System information cache
if (( ! ${+_zlog_sys_cache} )); then
  typeset -gA _zlog_sys_cache=(
    [hostname]=""
    [username]=""
    [pid]="$$"
  )
fi

# Color support cache
if (( ! ${+_zlog_color_cache} )); then
  typeset -gA _zlog_color_cache=(
    [mode]="auto"
    [initialized]=0
  )
  typeset -gA _zlog_colors=()
fi

###############################################################################
# FEATURE STORAGE
###############################################################################

# Context logging
if (( ! ${+_zlog_contexts} )); then
  typeset -gA _zlog_contexts=()
  typeset -gA _zlog_contexts_parsed=()
  typeset -ga _zlog_contexts_order=()
fi

# Benchmark timers
if (( ! ${+_zlog_benchmark_timers} )); then
  typeset -gA _zlog_benchmark_timers=()
  typeset -ga _zlog_benchmark_timer_order=()
fi

# Rate limiting
if (( ! ${+_zlog_rate_limits} )); then
  typeset -gA _zlog_rate_limits=()
fi

# Once logging
if (( ! ${+_zlog_once_keys} )); then
  typeset -gA _zlog_once_keys=()
fi

# Message buffer
if (( ! ${+_zlog_buffer} )); then
  typeset -ga _zlog_buffer=()
fi

###############################################################################
# PERFORMANCE OPTIMIZATION GLOBALS
###############################################################################

# Pre-allocated strings
if (( ! ${+_zlog_static} )); then
  typeset -gA _zlog_static=(
    [empty]=""
    [space]=" "
    [newline]=$'\n'
    [tab]=$'\t'
    [null]="null"
  )
fi

# Compiled regex patterns (cache for performance)
if (( ! ${+_zlog_patterns} )); then
  typeset -gA _zlog_patterns=(
    [number]='^[0-9]+$'
    [decimal]='^[0-9]+\\.?[0-9]*$'
    [context_key]='^[a-zA-Z_][a-zA-Z0-9_-]*$'
    [timer_id]='^zbt_[0-9]+_[0-9]+_[0-9]+$'
    [context_id]='^zlog_ctx_[0-9]+_[0-9]+_[0-9]+$'
    [size_suffix]='^([0-9]+\\.?[0-9]*)([KMGT]?B?)$'
  )
fi

###############################################################################
# STATISTICS TRACKING
###############################################################################

if (( ! ${+_zlog_stats} )); then
  typeset -gA _zlog_stats=(
    [messages_logged]=0
    [messages_dropped]=0
    [rotations_performed]=0
    [buffer_flushes]=0
    [errors_encountered]=0
  )
fi

###############################################################################
# INITIALIZATION FUNCTION
###############################################################################

__z::log::init_globals() {
  (( _zlog_initialized )) && return 0
  _zlog_initialized=1

  # Cache system information
  _zlog_sys_cache[pid]="$$"
  _zlog_sys_cache[hostname]="${HOST:-$(hostname 2>/dev/null || print -r -- unknown)}"
  _zlog_sys_cache[username]="${USER:-${USERNAME:-$(whoami 2>/dev/null || print -r -- unknown)}}"

  # Detect stat command type
  if command -v gstat &>/dev/null; then
    _zlog_state[stat_cmd]="gnu"
  elif stat -f%z / &>/dev/null 2>&1; then
    _zlog_state[stat_cmd]="bsd"
  elif stat -c%s / &>/dev/null 2>&1; then
    _zlog_state[stat_cmd]="gnu"
  else
    _zlog_state[stat_cmd]="none"
  fi

  # Check strftime availability
  if strftime "%Y" "$EPOCHSECONDS" >/dev/null 2>&1; then
    _zlog_cache[strftime_available]=1
  else
    _zlog_cache[strftime_available]=0
  fi

  # Update fast-path flags
  __z::log::update_fast_flags

  return 0
}

###############################################################################
# FAST-PATH FLAG UPDATER
###############################################################################

__z::log::update_fast_flags() {
  emulate -L zsh
  setopt localoptions no_unset

  _zlog_state[console_enabled]=$(( _zlog_config[level] >= 0 ))
  _zlog_state[file_enabled]=$(( ${#_zlog_config[file]} > 0 ))
  _zlog_state[any_logging_enabled]=$((
    _zlog_state[console_enabled] || _zlog_state[file_enabled]
  ))

  return 0
}

# Auto-initialize
__z::log::init_globals

###############################################################################
# CONFIGURATION VALIDATION
###############################################################################

__z::log::validate_globals() {
  emulate -L zsh
  setopt no_unset

  local -i changed=0

  # Validate rotate_size
  if (( _zlog_config[rotate_size] < _ZLOG_MIN_ROTATE_SIZE )); then
    if (( _zlog_config[debug_mode] )); then
      print -r -u2 -- "zlog: Warning: rotate_size too small (${_zlog_config[rotate_size]}), setting to ${_ZLOG_MIN_ROTATE_SIZE} bytes"
    fi
    _zlog_config[rotate_size]=$_ZLOG_MIN_ROTATE_SIZE
    (( changed++ ))
  elif (( _zlog_config[rotate_size] > _ZLOG_MAX_ROTATE_SIZE )); then
    if (( _zlog_config[debug_mode] )); then
      print -r -u2 -- "zlog: Warning: rotate_size too large (${_zlog_config[rotate_size]}), setting to ${_ZLOG_MAX_ROTATE_SIZE} bytes"
    fi
    _zlog_config[rotate_size]=$_ZLOG_MAX_ROTATE_SIZE
    (( changed++ ))
  fi

  # Validate buffer_max
  if (( _zlog_config[buffer_max] < _ZLOG_MIN_BUFFER_SIZE )); then
    _zlog_config[buffer_max]=$_ZLOG_MIN_BUFFER_SIZE
    (( changed++ ))
  elif (( _zlog_config[buffer_max] > _ZLOG_MAX_BUFFER_SIZE )); then
    _zlog_config[buffer_max]=$_ZLOG_MAX_BUFFER_SIZE
    (( changed++ ))
  fi

  # Validate log level
  if (( _zlog_config[level] < 0 || _zlog_config[level] > 3 )); then
    if (( _zlog_config[debug_mode] )); then
      print -r -u2 -- "zlog: Warning: invalid log level (${_zlog_config[level]}), resetting to INFO"
    fi
    _zlog_config[level]=2
    (( changed++ ))
  fi

  # Validate file level
  if (( _zlog_config[file_level] < -1 || _zlog_config[file_level] > 3 )); then
    if (( _zlog_config[debug_mode] )); then
      print -r -u2 -- "zlog: Warning: invalid file log level (${_zlog_config[file_level]}), setting to follow console"
    fi
    _zlog_config[file_level]=-1
    (( changed++ ))
  fi

  # Validate format
  if [[ "${_zlog_config[format]}" != "text" ]] && [[ "${_zlog_config[format]}" != "json" ]]; then
    if (( _zlog_config[debug_mode] )); then
      print -r -u2 -- "zlog: Warning: invalid format (${_zlog_config[format]}), resetting to text"
    fi
    _zlog_config[format]="text"
    (( changed++ ))
  fi

  # Validate rotate_keep
  if (( _zlog_config[rotate_keep] < 0 )); then
    _zlog_config[rotate_keep]=0
    (( changed++ ))
  elif (( _zlog_config[rotate_keep] > 100 )); then
    if (( _zlog_config[debug_mode] )); then
      print -r -u2 -- "zlog: Warning: rotate_keep too large (${_zlog_config[rotate_keep]}), setting to 100"
    fi
    _zlog_config[rotate_keep]=100
    (( changed++ ))
  fi

  # Validate rotation_lock_timeout
  if (( _zlog_config[rotation_lock_timeout] < 1 )); then
    _zlog_config[rotation_lock_timeout]=1
    (( changed++ ))
  elif (( _zlog_config[rotation_lock_timeout] > 60 )); then
    _zlog_config[rotation_lock_timeout]=60
    (( changed++ ))
  fi

  # Validate max_depth
  if (( _zlog_config[max_depth] < 1 )); then
    _zlog_config[max_depth]=1
    (( changed++ ))
  elif (( _zlog_config[max_depth] > 20 )); then
    _zlog_config[max_depth]=20
    (( changed++ ))
  fi

  # Validate max_message_size
  if (( _zlog_config[max_message_size] < 0 )); then
    _zlog_config[max_message_size]=0
    (( changed++ ))
  fi

  # Update fast-path flags if anything changed
  if (( changed )); then
    __z::log::update_fast_flags
  fi

  return 0
}
###############################################################################
# COLOR SYSTEM (UNIFIED WITH TRUE COLOR SUPPORT)
###############################################################################

###
# Detect terminal color capability
# Returns: "none", "basic" (16 colors), "256", or "truecolor"
# Output: Sets REPLY variable with detected mode
###
__z::log::detect_color_support() {
  emulate -L zsh
  setopt localoptions no_unset

  # Check NO_COLOR environment variable (standard)
  if [[ -n ${NO_COLOR-} ]]; then
    REPLY="none"
    return 0
  fi

  # Check if output is to terminal (stderr for logging)
  if [[ ! -t 2 ]]; then
    REPLY="none"
    return 0
  fi

  # Check TERM variable
  local term="${TERM-dumb}"
  if [[ "$term" == "dumb" ]]; then
    REPLY="none"
    return 0
  fi

  # Check for true color support
  case "${COLORTERM-}" in
    truecolor|24bit)
      REPLY="truecolor"
      return 0
      ;;
  esac

  # Check TERM for true color indicators
  if [[ "$term" == *truecolor* ]] || [[ "$term" == *24bit* ]]; then
    REPLY="truecolor"
    return 0
  fi

  # Check for 256 color support
  if [[ "$term" == *256* ]]; then
    REPLY="256"
    return 0
  fi

  # Check tput for color count
  if command -v tput &>/dev/null; then
    local colors
    colors=$(tput colors 2>/dev/null) || colors=0

    if [[ -n "$colors" ]] && [[ "$colors" =~ ^[0-9]+$ ]]; then
      if (( colors >= 256 )); then
        REPLY="256"
        return 0
      elif (( colors >= 16 )); then
        REPLY="basic"
        return 0
      fi
    fi
  fi

  # Default to basic 16 colors for common terminals
  case "$term" in
    xterm*|screen*|tmux*|rxvt*|linux*|vt*)
      REPLY="basic"
      ;;
    *)
      REPLY="none"
      ;;
  esac

  return 0
}

###
# Convert RGB to ANSI 256-color code (for 256-color mode)
# Usage: __z::log::rgb_to_256 R G B
#        local code="$REPLY"
###
__z::log::rgb_to_256() {
  emulate -L zsh
  setopt localoptions no_unset

  # Validate we have exactly 3 arguments
  if (( $# != 3 )); then
    REPLY="15"
    return 1
  fi

  local r=$1 g=$2 b=$3

  if [[ ! "$r" =~ ^[0-9]+$ ]] || [[ ! "$g" =~ ^[0-9]+$ ]] || [[ ! "$b" =~ ^[0-9]+$ ]]; then
    REPLY="15"
    return 1
  fi

  # Validate range (0-255)
  if (( r > 255 || g > 255 || b > 255 || r < 0 || g < 0 || b < 0 )); then
    REPLY="15"
    return 1
  fi

  # Check if it's grayscale (all components equal)
  if (( r == g && g == b )); then
    if (( r < 8 )); then
      REPLY="16"  # Black
    elif (( r >= 248 )); then
      REPLY="231"  # White
    else
      # Grayscale ramp: 232-255 (24 steps)
      REPLY=$(( 232 + (r - 8) / 10 ))
      (( REPLY > 255 )) && REPLY=255
    fi
    return 0
  fi

  # Convert to 6x6x6 color cube (216 colors: 16-231)
  local r6=$(( r * 6 / 256 ))
  local g6=$(( g * 6 / 256 ))
  local b6=$(( b * 6 / 256 ))

  REPLY=$(( 16 + 36 * r6 + 6 * g6 + b6 ))
  return 0
}

###
# Create ANSI color code from RGB values
# Usage: __z::log::rgb_color R G B [bg]
#        local code="$REPLY"
###
__z::log::rgb_color() {
  emulate -L zsh
  setopt localoptions no_unset

  # Validate input count
  if (( $# < 3 || $# > 4 )); then
    REPLY=""
    return 1
  fi

  local r=$1 g=$2 b=$3
  local is_bg="${4-}"

  if [[ ! "$r" =~ ^[0-9]+$ ]] || [[ ! "$g" =~ ^[0-9]+$ ]] || [[ ! "$b" =~ ^[0-9]+$ ]]; then
    REPLY=""
    return 1
  fi

  # Validate range
  if (( r > 255 || g > 255 || b > 255 || r < 0 || g < 0 || b < 0 )); then
    REPLY=""
    return 1
  fi

  # Determine color mode if not initialized
  local mode="${_zlog_color_cache[mode]}"
  if [[ "$mode" == "auto" ]]; then
    __z::log::detect_color_support
    mode="$REPLY"
  fi

  case "$mode" in
    truecolor)
      if [[ "$is_bg" == "bg" ]]; then
        REPLY=$'\e[48;2;'"${r};${g};${b}m"
      else
        REPLY=$'\e[38;2;'"${r};${g};${b}m"
      fi
      ;;
    256)
      __z::log::rgb_to_256 "$r" "$g" "$b" || return 1
      local code="$REPLY"
      if [[ "$is_bg" == "bg" ]]; then
        REPLY=$'\e[48;5;'"${code}m"
      else
        REPLY=$'\e[38;5;'"${code}m"
      fi
      ;;
    *)
      REPLY=""
      ;;
  esac

  return 0
}

###
# Initialize color codes
# Usage: __z::log::init_colors [force]
###
__z::log::init_colors() {
  emulate -L zsh
  setopt localoptions no_unset

  local force="${1:-0}"

  # Already initialized - prevent re-entry unless forced
  if (( _zlog_color_cache[initialized] && ! force )); then
    return 0
  fi

  # Mark as initializing immediately
  _zlog_color_cache[initialized]=1

  # Verbose initialization
  if [[ -n "${ZLOG_VERBOSE_INIT-}" ]]; then
    print -r -u2 -- "zlog: Initializing color system..."
  fi

  # Detect color support if in auto mode
  if [[ "${_zlog_color_cache[mode]}" == "auto" ]]; then
    __z::log::detect_color_support
    _zlog_color_cache[mode]="$REPLY"
  fi

  # If no color support, initialize empty
  if [[ "${_zlog_color_cache[mode]}" == "none" ]]; then
    _zlog_colors=(
      [reset]="" [bold]="" [dim]="" [underline]="" [blink]="" [reverse]="" [hidden]=""
      [black]="" [red]="" [green]="" [yellow]="" [blue]="" [magenta]="" [cyan]="" [white]=""
      [bright_black]="" [bright_red]="" [bright_green]="" [bright_yellow]=""
      [bright_blue]="" [bright_magenta]="" [bright_cyan]="" [bright_white]=""
      [bg_black]="" [bg_red]="" [bg_green]="" [bg_yellow]=""
      [bg_blue]="" [bg_magenta]="" [bg_cyan]="" [bg_white]=""
      [bg_bright_black]="" [bg_bright_red]="" [bg_bright_green]="" [bg_bright_yellow]=""
      [bg_bright_blue]="" [bg_bright_magenta]="" [bg_bright_cyan]="" [bg_bright_white]=""
      [error]="" [warn]="" [info]="" [debug]="" [success]=""
      [bg_error]="" [bg_warn]="" [bg_info]="" [bg_debug]="" [bg_success]=""
    )

    if [[ -n "${ZLOG_VERBOSE_INIT-}" ]]; then
      print -r -u2 -- "zlog: Color system ready (mode: none)"
    fi

    return 0
  fi

  # Use tput if available for basic attributes
  if command -v tput &>/dev/null; then
    _zlog_colors[reset]=$(tput sgr0 2>/dev/null) || _zlog_colors[reset]=$'\e[0m'
    _zlog_colors[bold]=$(tput bold 2>/dev/null) || _zlog_colors[bold]=$'\e[1m'
    _zlog_colors[dim]=$(tput dim 2>/dev/null) || _zlog_colors[dim]=$'\e[2m'
    _zlog_colors[underline]=$(tput smul 2>/dev/null) || _zlog_colors[underline]=$'\e[4m'
    _zlog_colors[blink]=$(tput blink 2>/dev/null) || _zlog_colors[blink]=$'\e[5m'
    _zlog_colors[reverse]=$(tput rev 2>/dev/null) || _zlog_colors[reverse]=$'\e[7m'
    _zlog_colors[hidden]=$(tput invis 2>/dev/null) || _zlog_colors[hidden]=$'\e[8m'
  else
    _zlog_colors[reset]=$'\e[0m'
    _zlog_colors[bold]=$'\e[1m'
    _zlog_colors[dim]=$'\e[2m'
    _zlog_colors[underline]=$'\e[4m'
    _zlog_colors[blink]=$'\e[5m'
    _zlog_colors[reverse]=$'\e[7m'
    _zlog_colors[hidden]=$'\e[8m'
  fi

