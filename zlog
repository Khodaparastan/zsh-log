}
###
# Apply color to text
# Usage: z::log::colorize COLOR_SPEC TEXT
#        print "$REPLY"
###
z::log::colorize() {
  emulate -L zsh
  setopt localoptions no_unset

  if (( $# < 2 )); then
    REPLY="${2-}"
    return 1
  fi

  # Auto-initialize colors on first use
  (( _zlog_color_cache[initialized] )) || __z::log::init_colors

  local color_spec="${1-}"
  local text="${2-}"

  # Normalize RGB spec: remove spaces
  color_spec="${color_spec// /}"

  local color_code=""

  # Check if it's an RGB specification
  # Use pattern variable to avoid escaping issues
  local rgb_pattern='rgb\(([0-9]+),([0-9]+),([0-9]+)(,bg)?\)'

  if [[ "$color_spec" =~ $rgb_pattern ]]; then
    local r="${match[1]}" g="${match[2]}" b="${match[3]}"
    local is_bg="${match[4]}"

    # Remove leading comma from bg flag if present
    is_bg="${is_bg#,}"

    # Validate RGB values
    if (( r > 255 || g > 255 || b > 255 )); then
      REPLY="$text"
      return 1
    fi

    __z::log::rgb_color "$r" "$g" "$b" "$is_bg"
    color_code="$REPLY"
  else
    # Named color from palette
    color_code="${_zlog_colors[$color_spec]-}"
  fi

  if [[ -n "$color_code" ]]; then
    REPLY="${color_code}${text}${_zlog_colors[reset]}"
  else
    REPLY="$text"
  fi

  return 0
}
###
# Set color mode manually
# Usage: z::log::set_color_mode MODE
###
z::log::set_color_mode() {
  emulate -L zsh
  setopt localoptions no_unset

  local mode="${1-}"

  if [[ -z "$mode" ]]; then
    print -r -u2 -- "zlog: Color mode cannot be empty (use: auto, none, basic, 256, truecolor)"
    return 1
  fi

  case "$mode" in
    auto|none|basic|256|truecolor)
      _zlog_color_cache[mode]="$mode"
      _zlog_color_cache[initialized]=0
      __z::log::init_colors 1  # Force re-init
      (( ${+functions[__z::log::debug_internal]} )) && \
        __z::log::debug_internal "Color mode set to: $mode"
      return 0
      ;;
    *)
      print -r -u2 -- "zlog: Invalid color mode: $mode (use: auto, none, basic, 256, truecolor)"
      return 1
      ;;
  esac
}

###
# Get current color mode
# Usage: mode=$(z::log::get_color_mode)
###
z::log::get_color_mode() {
  emulate -L zsh
  setopt localoptions no_unset

  # Initialize if needed
  (( _zlog_color_cache[initialized] )) || __z::log::init_colors

  print -r -- "${_zlog_color_cache[mode]}"
}

###
# Show available colors
# Usage: z::log::show_colors
###
z::log::show_colors() {
  emulate -L zsh
  setopt localoptions no_unset

  (( _zlog_color_cache[initialized] )) || __z::log::init_colors

  print -r -- "Color Mode: ${_zlog_color_cache[mode]}"
  print -r -- ""
  print -r -- "Basic Colors:"

  local color
  for color in black red green yellow blue magenta cyan white; do
    z::log::colorize "$color" "  ■ $color"
    print -r -- "$REPLY"
  done

  print -r -- ""
  print -r -- "Bright Colors:"
  for color in bright_black bright_red bright_green bright_yellow bright_blue bright_magenta bright_cyan bright_white; do
    z::log::colorize "$color" "  ■ $color"
    print -r -- "$REPLY"
  done

  print -r -- ""
  print -r -- "Log Level Colors:"
  for color in error warn info debug success; do
    z::log::colorize "$color" "  ■ $color"
    print -r -- "$REPLY"
  done

  print -r -- ""
  print -r -- "RGB Example (if supported):"
  z::log::colorize "rgb(255,100,50)" "  ■ rgb(255,100,50) - Custom orange"
  print -r -- "$REPLY"
}
