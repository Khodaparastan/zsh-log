###
# Temporarily change log level for a code block
# Restores original level afterwards
#
# Usage:
#   z::log::with_level debug command arg1 arg2
#
# Arguments:
#   new_level - Temporary log level (error/warn/info/debug or 0-3)
#   command... - Command and arguments to execute
#
# Returns:
#   Exit code of the executed command
###
z::log::with_level() {
  emulate -L zsh
  setopt localoptions

  # Validate input
  if (( $# < 2 )); then
    print -r -u2 -- "zlog: with_level requires level and command"
    return 1
  fi

  local new_level="$1"
  shift

  # Save current level
  local saved_level="${_zlog_config[level]:-2}"

  # Validate and set new level
  __z::log::level_number "$new_level"
  local level_status=$?
  local level_num="$REPLY"

  if (( level_status != 0 )); then
    print -r -u2 -- "zlog: Invalid level for with_level: $new_level"
    return 1
  fi

  local exit_code
  {
  _zlog_config[level]=$level_num
    __z::log::update_fast_flags
  "$@"
  exit_code=$?
  } always {
  _zlog_config[level]=$saved_level
    __z::log::update_fast_flags
  }

  return $exit_code
}
###
# Temporarily disable logging for a code block
#
# Usage:
#   z::log::silent command arg1 arg2
#
# Arguments:
#   command... - Command and arguments to execute
#
# Returns:
#   Exit code of the executed command
###
z::log::silent() {
  emulate -L zsh
  setopt localoptions

  # Validate input
  if (( $# < 1 )); then
    print -r -u2 -- "zlog: silent requires a command to execute"
    return 1
  fi

  # Save current levels
  local saved_console="${_zlog_config[level]:-2}"
  local saved_file="${_zlog_config[file_level]:--1}"

  local exit_code
  {
  _zlog_config[level]=-1
  _zlog_config[file_level]=-1
    __z::log::update_fast_flags
  "$@"
  exit_code=$?
  } always {
  _zlog_config[level]=$saved_console
  _zlog_config[file_level]=$saved_file
    __z::log::update_fast_flags
  }

  return $exit_code
}
###
# Log to both console and file regardless of level settings
# Useful for critical messages that must always be logged
#
# Usage:
#   z::log::always "Critical system event" [key val ...]
#
# Arguments:
#   message - Message to log (required)
#   ... - Optional key-value pairs for context
#
# Returns: 0 always
###
z::log::always() {
  emulate -L zsh
  setopt localoptions

  # Validate input
  if (( $# < 1 )); then
    print -r -u2 -- "zlog: always requires a message"
    return 1
  fi

  local message="$1"
  shift

  # Save current levels
  local saved_console="${_zlog_config[level]:-2}"
  local saved_file="${_zlog_config[file_level]:--1}"

  local result_status=0
  {
    # Temporarily set to error level (always logged)
    _zlog_config[level]=${_ZLOG_LEVEL_ERROR:-0}
    _zlog_config[file_level]=${_ZLOG_LEVEL_ERROR:-0}
    __z::log::update_fast_flags

    # Log as error
    __z::log::engine "${_ZLOG_LEVEL_ERROR}" "$message" "$@"
    result_status=$?
  } always {
    # Restore levels
    _zlog_config[level]=$saved_console
    _zlog_config[file_level]=$saved_file
    __z::log::update_fast_flags
  }

  return $result_status
}

###
# Log a message only once (subsequent calls with same key are ignored)
# Useful for avoiding log spam in loops
#
# Usage:
#   z::log::once "unique_key" info "This will only log once"
#
# Arguments:
#   key - Unique identifier for this message
#   level - Log level (error/warn/info/debug)
#   message - Message to log
#   ... - Optional key-value pairs for context
#
# Returns: 0 always
###
z::log::once() {
  emulate -L zsh
  setopt localoptions

  # Validate input
  if (( $# < 3 )); then
    print -r -u2 -- "zlog: once requires key, level, and message"
    return 1
  fi

  local key="$1"
  local level="$2"
  local message="$3"
  shift 3

  if [[ -z "$key" ]]; then
    print -r -u2 -- "zlog: once key cannot be empty"
    return 1
  fi

  if [[ -n "${_zlog_once_keys[$key]-}" ]]; then
    return 0
  fi

  __z::log::level_number "$level" || {
    print -r -u2 -- "zlog: Invalid level for once: $level"
    return 1
  }
  local level_num="$REPLY"

  if ! __z::log::is_level_active "$level_num"; then
    return 0
  fi

  # Log the message
  z::log::log "$level_num" "$message" "$@"
  local log_status=$?

  if (( log_status == 0 )); then
    _zlog_once_keys[$key]=1
  fi

  return $log_status
}

###
# Clear all "log once" markers
# Allows previously logged "once" messages to be logged again
#
# Usage:
#   z::log::clear_once [key]
#
# Arguments:
#   key - Optional specific key to clear (if omitted, clears all)
#
# Returns: 0 always
###
z::log::clear_once() {
  emulate -L zsh
  setopt localoptions

  local key="${1-}"

  if [[ -n "$key" ]]; then
    unset "_zlog_once_keys[$key]"
    __z::log::debug_internal "Cleared once marker: $key"
  else
    _zlog_once_keys=()
    __z::log::debug_internal "Cleared all once markers"
  fi

  return 0
}

###
# Log with rate limiting (max N messages per time period)
# Useful for preventing log floods
#
# Usage:
#   z::log::rate_limit "key" 5 60 info "Rate limited message"
#   # Allows max 5 messages per 60 seconds
#
# Arguments:
#   key - Unique identifier for this rate limit
#   max_count - Maximum number of messages allowed
#   time_window - Time window in seconds
#   level - Log level
#   message - Message to log
#   ... - Optional key-value pairs
#
# Returns: 0 if logged, 1 if rate limited
###
z::log::rate_limit() {
  emulate -L zsh
  setopt localoptions

  # Validate input
  if (( $# < 5 )); then
    print -r -u2 -- "zlog: rate_limit requires key, max_count, time_window, level, and message"
    return 1
  fi

  local key="$1"
  local max_count="$2"
  local time_window="$3"
  local level="$4"
  local message="$5"
  shift 5

  if [[ -z "$key" ]]; then
    print -r -u2 -- "zlog: rate_limit key cannot be empty"
    return 1
  fi

  # Validate max_count
  if [[ ! "$max_count" =~ '^[0-9]+$' ]] || (( max_count < 1 )); then
    print -r -u2 -- "zlog: rate_limit max_count must be a positive integer"
    return 1
  fi

  # Validate time_window
  if [[ ! "$time_window" =~ '^[0-9]+$' ]] || (( time_window < 1 )); then
    print -r -u2 -- "zlog: rate_limit time_window must be a positive integer"
    return 1
  fi

  __z::log::level_number "$level" || {
    print -r -u2 -- "zlog: Invalid level for rate_limit: $level"
    return 1
  }
  local level_num="$REPLY"

  if ! __z::log::is_level_active "$level_num"; then
    return 0
  fi

  local current_time=$EPOCHSECONDS

  # Get existing rate limit data (format: "timestamp:count")
  local rate_data="${_zlog_rate_limits[$key]-}"

  if [[ -n "$rate_data" && ! "$rate_data" =~ '^[0-9]+:[0-9]+$' ]]; then
    __z::log::debug_internal "Resetting corrupt rate limit state for key: $key"
    rate_data=""
  fi

  if [[ -z "$rate_data" ]]; then
    # First message - initialize
    _zlog_rate_limits[$key]="${current_time}:1"
    z::log::log "$level_num" "$message" "$@"
    return 0
  fi

  # Parse existing data
  local window_start="${rate_data%%:*}"
  local count="${rate_data##*:}"

  # Check if we're in a new time window
  if (( current_time - window_start >= time_window )); then
    # New window - reset
    _zlog_rate_limits[$key]="${current_time}:1"
    z::log::log "$level_num" "$message" "$@"
    return 0
  fi

  # Same window - check count
  if (( count < max_count )); then
    # Under limit - log and increment
    _zlog_rate_limits[$key]="${window_start}:$((count + 1))"
    z::log::log "$level_num" "$message" "$@"
    return 0
  fi

  # Rate limited - don't log
  (( _zlog_stats[messages_dropped]++ ))
  __z::log::debug_internal "Rate limited: $key ($count/$max_count in ${time_window}s window)"
  return 1
}

###
# Clear all rate limit counters
#
# Usage:
#   z::log::clear_rate_limits [key]
#
# Arguments:
#   key - Optional specific key to clear (if omitted, clears all)
#
# Returns: 0 always
###
z::log::clear_rate_limits() {
  emulate -L zsh
  setopt localoptions

  local key="${1-}"

  if [[ -n "$key" ]]; then
    unset "_zlog_rate_limits[$key]"
    __z::log::debug_internal "Cleared rate limit: $key"
  else
    _zlog_rate_limits=()
    __z::log::debug_internal "Cleared all rate limits"
  fi

  return 0
}
###############################################################################
# CONTEXT LOGGING SYSTEM
###############################################################################

###
# Create a context logger with fixed key-value pairs
# Sets REPLY variable with the context ID
#
# Usage:
#   z::log::with_context "request_id" "abc123" "user" "john"
#   local ctx="$REPLY"
#   ${ctx}::info "User action completed"
#   ${ctx}::debug "Processing step 5"
#
# Arguments:
#   key1 value1 [key2 value2 ...] - Key-value pairs (must be even number of args)
#
# Returns:
#   0 on success, 1 on error
#   Sets REPLY variable with context ID
###
z::log::with_context() {
  emulate -L zsh
  setopt localoptions

  # Validate input
  if (( $# < 2 || $# % 2 != 0 )); then
    print -r -u2 -- "zlog: with_context requires even number of arguments (key-value pairs), got $#"
    return 1
  fi

  # Validate context keys and values
  local -a context_pairs=("$@")
  local i
  for (( i=1; i<=${#context_pairs}; i+=2 )); do
    local key="${context_pairs[i]}"

    if ! __z::log::validate_context_key "$key"; then
      print -r -u2 -- "zlog: Invalid context key at position $i: $key"
      return 1
    fi
  done

  # Check context limit and cleanup if necessary
  if (( ${#_zlog_contexts} >= ${_ZLOG_MAX_CONTEXTS:-100} )); then
    __z::log::debug_internal "Context limit (${_ZLOG_MAX_CONTEXTS:-100}) reached, cleaning oldest context"
    __z::log::cleanup_oldest_context
  fi

  local ctx_id
  local max_attempts=10
  local attempt=0

  while (( attempt < max_attempts )); do
    # Use multiple sources of randomness for better uniqueness
    ctx_id="zlog_ctx_${RANDOM}${RANDOM}_${EPOCHSECONDS}_$$"

    # Check for collision
    [[ -z "${_zlog_contexts[$ctx_id]-}" ]] && break

    (( attempt++ ))
  done

  if (( attempt >= max_attempts )); then
    print -r -u2 -- "zlog: Failed to generate unique context ID after $max_attempts attempts"
    REPLY=""
    return 1
  fi

  # Store context data (null-separated for easy splitting)
  _zlog_contexts[$ctx_id]="${(pj:\0:)context_pairs}"
  _zlog_contexts_order+=("$ctx_id")
  _zlog_state[context_count]=${#_zlog_contexts}

  # Create logging functions for this context
  if ! __z::log::create_context_functions "$ctx_id"; then
    print -r -u2 -- "zlog: Failed to create context functions for $ctx_id"
    unset "_zlog_contexts[$ctx_id]"
    _zlog_contexts_order=("${(@)_zlog_contexts_order:#$ctx_id}")
    _zlog_state[context_count]=${#_zlog_contexts}
    REPLY=""
    return 1
  fi

  # Set REPLY with context ID
  REPLY="$ctx_id"

  __z::log::debug_internal "Created context: $ctx_id"
  return 0
}

###
# Internal: Create all logging functions for a context
###
__z::log::create_context_functions() {
  emulate -L zsh
  setopt localoptions

  local ctx_id="${1-}"

  # Validate context ID format
  if [[ ! "$ctx_id" =~ ^zlog_ctx_[0-9]+_[0-9]+_[0-9]+$ ]]; then
    print -r -u2 -- "zlog: Invalid context ID format: $ctx_id"
    return 1
  fi

  # Create all 8 logging functions (4 levels × 2 variants)
  local level
  for level in error warn info debug; do
    __z::log::create_context_function "$ctx_id" "$level" "false" || return 1
    __z::log::create_context_function "$ctx_id" "$level" "true" || return 1
  done

  return 0
}

###
# Internal: Create a single context logging function
# Uses eval to create functions in current shell scope
###
__z::log::create_context_function() {
  emulate -L zsh
  setopt localoptions

  local ctx_id="${1-}"
  local level="${2-}"
  local formatted="${3-}"

  local func_name="${ctx_id}::${level}"
  [[ "$formatted" == "true" ]] && func_name="${func_name}f"

  # Validate function name format
  if [[ ! "$func_name" =~ ^zlog_ctx_[0-9]+_[0-9]+_[0-9]+::(error|warn|info|debug)f?$ ]]; then
    print -r -u2 -- "zlog: Invalid function name: $func_name"
    return 1
  fi

  # Create function using eval
  # The function body is self-contained
  if [[ "$formatted" == "true" ]]; then
    # Printf-style context function
    eval "
function ${func_name}() {
  emulate -L zsh
  setopt localoptions no_unset
  local func_name=\"\${0}\"
  local func_ctx_id=\"\${func_name%%::*}\"
  local func_level=\"\${func_name##*::}\"
  func_level=\"\${func_level%f}\"

  if [[ -z \"\${_zlog_contexts[\$func_ctx_id]-}\" ]]; then
    print -r -u2 -- \"zlog: Context \$func_ctx_id no longer exists\"
    return 1
  fi

  if (( \$# < 1 )); then
    print -r -u2 -- \"zlog: \$func_name requires a format string\"
    return 1
  fi

  local fmt=\"\$1\"
  shift
  local msg
  if printf -v msg -- \"\$fmt\" \"\$@\" 2>/dev/null; then
    :
  else
    msg=\"<printf error: \$fmt>\"
  fi

  local -a ctx_args
  ctx_args=(\"\${(@0)_zlog_contexts[\$func_ctx_id]}\")
  z::log::\${func_level} \"\$msg\" \"\${ctx_args[@]}\"
}
"
  else
    # Regular context function
    eval "
function ${func_name}() {
  emulate -L zsh
  setopt localoptions no_unset
  local func_name=\"\${0}\"
  local func_ctx_id=\"\${func_name%%::*}\"
  local func_level=\"\${func_name##*::}\"

  if [[ -z \"\${_zlog_contexts[\$func_ctx_id]-}\" ]]; then
    print -r -u2 -- \"zlog: Context \$func_ctx_id no longer exists\"
    return 1
  fi

  if (( \$# < 1 )); then
    print -r -u2 -- \"zlog: \$func_name requires a message\"
    return 1
  fi

  local msg=\"\$1\"
  shift
  local -a ctx_args
  ctx_args=(\"\${(@0)_zlog_contexts[\$func_ctx_id]}\")
  z::log::\${func_level} \"\$msg\" \"\${ctx_args[@]}\" \"\$@\"
}
"
  fi

  local eval_status=$?
  if (( eval_status != 0 )); then
    print -r -u2 -- "zlog: eval failed for function $func_name (status: $eval_status)"
    return 1
  fi

  # Verify function was created
  if (( ! ${+functions[$func_name]} )); then
    print -r -u2 -- "zlog: Failed to create function: $func_name"
    return 1
  fi

  __z::log::debug_internal "Created context function: $func_name"
  return 0
}

###
# Internal: Clean up the oldest context
# Does not use logging to avoid recursion
###
__z::log::cleanup_oldest_context() {
  emulate -L zsh
  setopt localoptions

  (( ${#_zlog_contexts_order} > 0 )) || return 0

  local oldest_ctx="${_zlog_contexts_order[1]}"

  # Remove without logging (to avoid recursion)
  __z::log::remove_context_silent "$oldest_ctx"
}

###
# Internal: Remove context without logging (prevents recursion)
###
__z::log::remove_context_silent() {
  emulate -L zsh
  setopt localoptions

  local ctx_id="${1-}"

  [[ -z "$ctx_id" ]] && return 1
  [[ -z "${_zlog_contexts[$ctx_id]-}" ]] && return 1

  # Remove from storage
  unset "_zlog_contexts[$ctx_id]"
  unset "_zlog_contexts_parsed[$ctx_id]" 2>/dev/null || true

  # Remove from order tracking
  _zlog_contexts_order=("${(@)_zlog_contexts_order:#$ctx_id}")
  _zlog_state[context_count]=${#_zlog_contexts}

  # Unset functions
  local level suffix
  for level in error warn info debug; do
    for suffix in "" "f"; do
      local func_name="${ctx_id}::${level}${suffix}"
      if (( ${+functions[$func_name]} )); then
        unfunction "$func_name" 2>/dev/null
        __z::log::debug_internal "Removed context function: $func_name"
      fi
    done
  done

  return 0
}

###
# Remove a context logger and clean up all associated resources
#
# Usage:
#   z::log::remove_context "$ctx"
#
# Arguments:
#   ctx_id - The context identifier returned by z::log::with_context
#
# Returns:
#   0 on success, 1 if context doesn't exist
###
z::log::remove_context() {
  emulate -L zsh
  setopt localoptions

  local ctx_id="${1-}"

  # Validate input
  if [[ -z "$ctx_id" ]]; then
    print -r -u2 -- "zlog: remove_context requires a context ID"
    return 1
  fi

  # Check if context exists
  if [[ -z "${_zlog_contexts[$ctx_id]-}" ]]; then
    print -r -u2 -- "zlog: Context $ctx_id does not exist or already removed"
    return 1
  fi

  # Use silent removal to avoid logging during cleanup
  __z::log::remove_context_silent "$ctx_id"

  return 0
}

###
# Remove all context loggers
#
# Usage:
#   z::log::remove_all_contexts
#
# Returns:
#   0 always
###
z::log::remove_all_contexts() {
  emulate -L zsh
  setopt localoptions

  # Use silent removal to avoid logging during bulk cleanup
  local ctx_id
  for ctx_id in "${_zlog_contexts_order[@]}"; do
    __z::log::remove_context_silent "$ctx_id"
  done

  # Clear all storage
  _zlog_contexts=()
  _zlog_contexts_parsed=()
  _zlog_contexts_order=()
  _zlog_state[context_count]=0

  return 0
}

###
# List all active context loggers
#
# Usage:
#   z::log::list_contexts
#
# Outputs:
#   Lines with format: <ctx_id> <key1>=<value1> <key2>=<value2> ...
###
z::log::list_contexts() {
  emulate -L zsh
  setopt localoptions

  if (( ${#_zlog_contexts_order} == 0 )); then
    print -r -- "No active contexts"
    return 0
  fi

  local ctx_id
  for ctx_id in "${_zlog_contexts_order[@]}"; do
    if [[ -n "${_zlog_contexts[$ctx_id]-}" ]]; then
      local -a ctx_data
      ctx_data=("${(@0)_zlog_contexts[$ctx_id]}")

      print -n "$ctx_id "

      local i
      for (( i=1; i<=${#ctx_data}; i+=2 )); do
        print -n "${ctx_data[i]}=${ctx_data[i+1]} "
      done

      print -r --
    fi
  done
}
###############################################################################
# BENCHMARKING UTILITIES
###############################################################################

###
# Benchmark a command or function
# Logs execution time at info level
#
# Usage:
#   z::log::benchmark "operation_name" command arg1 arg2 ...
#
# Arguments:
#   operation_name - Descriptive name for the operation
#   command... - Command and arguments to execute
#
# Returns:
#   Exit code of the executed command
#
# Note: Only performs timing if info level logging is enabled
###
z::log::benchmark() {
  emulate -L zsh
  setopt localoptions

  # Validate input
  if (( $# < 2 )); then
    print -r -u2 -- "zlog: benchmark requires operation name and command"
    return 1
  fi

  local operation_name="$1"
  shift

  # Validate operation name
  if [[ -z "$operation_name" ]]; then
    print -r -u2 -- "zlog: benchmark operation name cannot be empty"
    return 1
  fi

  # Only benchmark if info level is active (performance optimization)
  if ! z::log::if_info; then
    # Just execute without timing
    "$@"
    return $?
  fi

  z::log::benchmark_now
  local start_time="$REPLY"

  # Execute command and capture exit code
  local exit_code
  "$@"
  exit_code=$?

  z::log::benchmark_now
  local end_time="$REPLY"

  # Calculate duration in milliseconds
  local duration_ms
  duration_ms=$(( end_time - start_time ))
  (( duration_ms < 0 )) && duration_ms=0

  # Format duration
  __z::log::format_duration "$duration_ms"
  local duration_str="$REPLY"

  # Log the benchmark result
  z::log::info "Benchmark: ${operation_name}" \
    "duration" "$duration_str" \
    "exit_code" "$exit_code"

  return $exit_code
}

###
# Start a named benchmark timer
#
# Usage:
#   z::log::benchmark_start "operation_name"
#   timer="$REPLY"
#   # ... do work ...
#   z::log::benchmark_end "$timer"
#
# Arguments:
#   operation_name - Descriptive name for the operation
#
# Returns:
#   0 on success, 1 on error
#   Sets REPLY variable with timer ID (empty if logging disabled)
###
z::log::benchmark_start() {
  emulate -L zsh
  setopt localoptions

  local operation_name="${1-}"

  # Validate input
  if [[ -z "$operation_name" ]]; then
    print -r -u2 -- "zlog: benchmark_start requires operation name"
    return 1
  fi

  # Only benchmark if info level is active
  if ! z::log::if_info; then
    # Return empty to signal no timing
    REPLY=""
    return 0
  fi

  # Check timer limit and cleanup if necessary
  if (( ${#_zlog_benchmark_timers} >= ${_ZLOG_MAX_TIMERS:-50} )); then
    __z::log::debug_internal "Timer limit (${_ZLOG_MAX_TIMERS:-50}) reached, cleaning oldest timer"
    __z::log::cleanup_oldest_timer
  fi

  # Generate unique timer ID with collision protection
  local timer_id
  local max_attempts=10
  local attempt=0

  while (( attempt < max_attempts )); do
    timer_id="zbt_${RANDOM}_${EPOCHSECONDS}_$$"

    # Check for collision
    [[ -z "${_zlog_benchmark_timers[$timer_id]-}" ]] && break

    (( attempt++ ))
  done

  if (( attempt >= max_attempts )); then
    print -r -u2 -- "zlog: Failed to generate unique timer ID after $max_attempts attempts"
    REPLY=""
    return 1
  fi

  # Store timer data: start_time|operation_name
  z::log::benchmark_now
  _zlog_benchmark_timers[$timer_id]="${REPLY}|${operation_name}"
  _zlog_benchmark_timer_order+=("$timer_id")
  _zlog_state[timer_count]=${#_zlog_benchmark_timers}

  # Return timer ID via REPLY
  REPLY="$timer_id"
  __z::log::debug_internal "Started timer: $timer_id for '$operation_name'"

  return 0
}

###
# End a named benchmark timer and log the result
#
# Usage:
#   z::log::benchmark_start "operation_name"
#   timer="$REPLY"
#   # ... do work ...
#   z::log::benchmark_end "$timer"
#
# Arguments:
#   timer_id - The timer identifier returned by z::log::benchmark_start
#
# Returns:
#   0 on success, 1 on error
###
z::log::benchmark_end() {
  emulate -L zsh
  setopt localoptions

  local timer_id="${1-}"

  # Handle empty timer (when info logging is disabled)
  if [[ -z "$timer_id" ]]; then
    return 0
  fi

  # Validate input format
  if [[ ! "$timer_id" =~ ^zbt_[0-9]+_[0-9]+_[0-9]+$ ]]; then
    print -r -u2 -- "zlog: Invalid timer ID format: $timer_id"
    return 1
  fi

  # Check if timer exists
  if [[ -z "${_zlog_benchmark_timers[$timer_id]-}" ]]; then
    print -r -u2 -- "zlog: Timer not found: $timer_id"
    return 1
  fi

  # Parse timer data
  local timer_data="${_zlog_benchmark_timers[$timer_id]}"
  local start_time="${timer_data%%|*}"
  local operation_name="${timer_data#*|}"

  if [[ ! "$start_time" =~ '^[0-9]+$' ]]; then
    print -r -u2 -- "zlog: Corrupt timer data for: $timer_id"
    unset "_zlog_benchmark_timers[$timer_id]"
    _zlog_benchmark_timer_order=("${(@)_zlog_benchmark_timer_order:#$timer_id}")
    _zlog_state[timer_count]=${#_zlog_benchmark_timers}
    return 1
  fi

  # Calculate duration
  z::log::benchmark_now
  local end_time="$REPLY"
  local duration_ms
  duration_ms=$(( end_time - start_time ))
  (( duration_ms < 0 )) && duration_ms=0

  # Format duration
  __z::log::format_duration "$duration_ms"
  local duration_str="$REPLY"

  # Log the benchmark result
  z::log::info "Benchmark completed: ${operation_name}" \
    "duration" "$duration_str"

  # Cleanup timer
  unset "_zlog_benchmark_timers[$timer_id]"
  _zlog_benchmark_timer_order=("${(@)_zlog_benchmark_timer_order:#$timer_id}")
  _zlog_state[timer_count]=${#_zlog_benchmark_timers}

  __z::log::debug_internal "Ended timer: $timer_id"

  return 0
}

###
# Benchmark a code block with automatic timing
#
# Usage:
#   z::log::benchmark_block "expensive_calculation" <<'END'
#     for i in {1..1000}; do
#       # some work
#     done
#   END
#
# Arguments:
#   operation_name - Descriptive name for the operation
#   stdin - Code block to execute
#
# Returns:
#   Exit code of the executed code block
###
z::log::benchmark_block() {
  emulate -L zsh
  setopt localoptions

  local operation_name="${1-}"

  # Validate input
  if [[ -z "$operation_name" ]]; then
    print -r -u2 -- "zlog: benchmark_block requires operation name"
    return 1
  fi

  # Only benchmark if info level is active
  if ! z::log::if_info; then
    # Just execute without timing
    eval "$(cat)"
    return $?
  fi

  z::log::benchmark_now
  local start_time="$REPLY"

  # Execute the code block from stdin
  local exit_code
  eval "$(cat)"
  exit_code=$?

  z::log::benchmark_now
  local end_time="$REPLY"

  # Calculate duration
  local duration_ms
  duration_ms=$(( end_time - start_time ))
  (( duration_ms < 0 )) && duration_ms=0

  # Format duration
  __z::log::format_duration "$duration_ms"
  local duration_str="$REPLY"

  z::log::info "Benchmark block: ${operation_name}" \
    "duration" "$duration_str" \
    "exit_code" "$exit_code"

  return $exit_code
}

###
# Internal: Cleanup oldest timer
###
__z::log::cleanup_oldest_timer() {
  emulate -L zsh
  setopt localoptions

  (( ${#_zlog_benchmark_timer_order} > 0 )) || return 0

  local oldest_timer="${_zlog_benchmark_timer_order[1]}"

  # Remove from storage
  unset "_zlog_benchmark_timers[$oldest_timer]"

  # Remove from order array (shift left)
  _zlog_benchmark_timer_order=("${(@)_zlog_benchmark_timer_order[2,-1]}")
  _zlog_state[timer_count]=${#_zlog_benchmark_timers}

  __z::log::debug_internal "Cleaned up oldest timer: $oldest_timer"
}

# Duration formatting is defined once in the timestamp utilities section.

###
# List all active benchmark timers
#
# Usage:
#   z::log::list_timers
#
# Outputs:
#   Lines with format: <timer_id> <operation_name> <elapsed_time>
###
z::log::list_timers() {
  emulate -L zsh
  setopt localoptions

  if (( ${#_zlog_benchmark_timer_order} == 0 )); then
    print -r -- "No active timers"
    return 0
  fi

  local timer_id
  for timer_id in "${_zlog_benchmark_timer_order[@]}"; do
    if [[ -n "${_zlog_benchmark_timers[$timer_id]-}" ]]; then
      local timer_data="${_zlog_benchmark_timers[$timer_id]}"
      local start_time="${timer_data%%|*}"
      local operation_name="${timer_data#*|}"

      # Calculate elapsed time
      local elapsed_ms=$(( (EPOCHREALTIME - start_time) * 1000 ))
      __z::log::format_duration "$elapsed_ms"
      local elapsed_str="$REPLY"

      print -r -- "$timer_id $operation_name (elapsed: $elapsed_str)"
    fi
  done
}

###
# Remove all active benchmark timers
#
# Usage:
#   z::log::clear_timers
#
# Returns:
#   0 always
###
z::log::clear_timers() {
  emulate -L zsh
  setopt localoptions

  local count=${#_zlog_benchmark_timer_order}

  _zlog_benchmark_timers=()
  _zlog_benchmark_timer_order=()
  _zlog_state[timer_count]=0

  __z::log::debug_internal "Cleared $count timer(s)"

  return 0
}

###############################################################################
# CLEANUP & RESOURCE MANAGEMENT
###############################################################################

###
# Cleanup function - flushes buffers and closes file handles
# Should be called on script exit or when logging is no longer needed
# Idempotent - safe to call multiple times
# Usage: z::log::cleanup
###
z::log::cleanup() {
  emulate -L zsh
  setopt localoptions no_unset

  (( ${_zlog_state[cleanup_running]:-0} )) && return 0
  _zlog_state[cleanup_running]=1

  {

  # Flush any buffered logs
  if (( ${#_zlog_buffer} > 0 )); then
    (( ${+functions[z::log::flush]} )) && z::log::flush 2>/dev/null || true
  fi
  _zlog_state[buffer_count]=${#_zlog_buffer}

  # Disable async logging after flushing so queued buffered messages can drain.
  if [[ -n "${_zlog_state[async_pid]:-}" ]]; then
    (( ${+functions[z::log::disable_async]} )) && z::log::disable_async 2>/dev/null || true
  fi

  # Close file descriptor if open
  if [[ "${_zlog_state[fd]:--1}" != "-1" ]]; then
    local zlog_fd="${_zlog_state[fd]}"
    exec {zlog_fd}>&- 2>/dev/null || true
    _zlog_state[fd]=-1
  fi

  # Clear all context loggers silently
  if (( ${#_zlog_contexts} > 0 )); then
    local ctx_id
    for ctx_id in ${(k)_zlog_contexts}; do
      (( ${+functions[__z::log::remove_context_silent]} )) && \
        __z::log::remove_context_silent "$ctx_id" 2>/dev/null || true
    done
  fi
  _zlog_contexts=()
  _zlog_contexts_parsed=()
  _zlog_contexts_order=()
  _zlog_state[context_count]=0

  # Clear benchmark timers
  if (( ${#_zlog_benchmark_timers} > 0 )); then
    _zlog_benchmark_timers=()
    _zlog_benchmark_timer_order=()
  fi
  _zlog_state[timer_count]=0

  # Clear rate limits and once keys
  if (( ${#_zlog_rate_limits} > 0 )); then
    _zlog_rate_limits=()
  fi

  if (( ${#_zlog_once_keys} > 0 )); then
    _zlog_once_keys=()
  fi

  } always {
    _zlog_state[cleanup_running]=0
  }

  return 0
}

###
# Register cleanup to run on EXIT
# Idempotent - safe to call multiple times
# Usage: z::log::register_cleanup
###
z::log::register_cleanup() {
  emulate -L zsh
  setopt localoptions no_unset

  # Guard: prevent multiple registrations
  (( ${_zlog_state[cleanup_registered]:-0} )) && return 0

  # Try to load add-zsh-hook if not available
  if (( ! ${+functions[add-zsh-hook]} )); then
    autoload -Uz add-zsh-hook 2>/dev/null
  fi

  # Try to use add-zsh-hook if available (cleaner, more composable)
  if (( ${+functions[add-zsh-hook]} )); then
    if add-zsh-hook zshexit z::log::cleanup 2>/dev/null; then
      _zlog_state[cleanup_registered]=1
      _zlog_config[exit_hook_method]="add-zsh-hook"
      return 0
    fi
  fi

  # Fallback: reversible TRAPEXIT wrapper.
  if (( ${+functions[TRAPEXIT]} && ! ${+functions[__zlog_original_TRAPEXIT]} )); then
    functions[__zlog_original_TRAPEXIT]="${functions[TRAPEXIT]}"
  fi

  function TRAPEXIT() {
    local zlog_status=$?
    if (( ${+functions[__zlog_original_TRAPEXIT]} )); then
      __zlog_original_TRAPEXIT
    fi
      z::log::cleanup
    return $zlog_status
  }

  _zlog_state[cleanup_registered]=1
  _zlog_config[exit_hook_method]="TRAPEXIT"

  return 0
}

###
# Get information about the exit hook method being used
# Returns: "zshexit", "trapexit", or "none"
# Usage: z::log::get_exit_hook_method
###
z::log::get_exit_hook_method() {
  emulate -L zsh
  setopt localoptions no_unset 2>/dev/null || true

  if (( ! ${_zlog_state[cleanup_registered]:-0} )); then
    print -r -- "none"
    return 0
  fi

  # Check if using zshexit hook
  if (( ${+zshexit_functions} )); then
    local -a hooks
    hooks=("${zshexit_functions[@]}")

    if (( ${hooks[(I)z::log::cleanup]} )); then
      print -r -- "zshexit"
      return 0
    fi
  fi

  # Check if using TRAPEXIT
  if (( ${+functions[TRAPEXIT]} )); then
    local trapexit_body="${functions[TRAPEXIT]}"

    if [[ "$trapexit_body" == *"z::log::cleanup"* ]]; then
      print -r -- "trapexit"
      return 0
    fi
  fi

  # If registered but not detected, assume trapexit (safest assumption)
  print -r -- "trapexit"
  return 0
}

###
# Unregister cleanup hook (for testing or manual control)
# Usage: z::log::unregister_cleanup
###
z::log::unregister_cleanup() {
  emulate -L zsh
  setopt localoptions no_unset

  # Guard: nothing to unregister
  (( ! ${_zlog_state[cleanup_registered]:-0} )) && return 0

  # Try to remove from zshexit hooks
  if (( ${+functions[add-zsh-hook]} )); then
    add-zsh-hook -d zshexit z::log::cleanup 2>/dev/null || true
  fi

  if (( ${+functions[__zlog_original_TRAPEXIT]} )); then
    functions[TRAPEXIT]="${functions[__zlog_original_TRAPEXIT]}"
    unfunction __zlog_original_TRAPEXIT 2>/dev/null || true
  elif [[ "${_zlog_config[exit_hook_method]:-}" == "TRAPEXIT" ]]; then
        unfunction TRAPEXIT 2>/dev/null || true
      fi

  _zlog_state[cleanup_registered]=0
  _zlog_config[exit_hook_method]=""

  return 0
}
