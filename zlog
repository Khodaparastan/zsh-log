__z::log::debug_internal() {
  emulate -L zsh
  setopt localoptions no_unset

  (( ${_zlog_config[debug_mode]:-0} )) || return 0

  local ts

  if ts=$(strftime "%H:%M:%S" "$EPOCHSECONDS" 2>/dev/null) && [[ -n "$ts" ]]; then
    : # Success
