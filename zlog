###
__z::log::printf_helper() {
  emulate -L zsh

  local level="${1-}"
  local format="${2-}"
  shift 2

  # Validate format string
  if [[ -z "$format" ]]; then
    print -r -u2 -- "zlog: printf format string cannot be empty"
