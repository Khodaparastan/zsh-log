###
# Generic log function (accepts level as first argument)
#
# Usage:
#   z::log::log "info" "message" [key val ...]
#   z::log::log 2 "Server started" "port" "8080"
#
# Arguments:
#   level - Log level (error/warn/info/debug or 0-3)
#   message - Log message (required)
#   ... - Optional key-value pairs for context
#
# Returns: 0 on success, 1 on invalid level
###
z::log::log() {
  emulate -L zsh
  setopt localoptions no_unset

  # Validate input
  if (( $# < 2 )); then
    print -r -u2 -- "zlog: log() requires level and message"
    return 1
  fi

  local level_input="$1"
  shift

  if (( ! _zlog_state[any_logging_enabled] )); then
    return 0
  fi

  # Convert level name to number
  __z::log::level_number "$level_input"
  local level_status=$?
  local level_num="$REPLY"

  if (( level_status != 0 )); then
    print -r -u2 -- "zlog: Invalid level: $level_input"
    return 1
  fi

  # Lazy evaluation
  local console_level="${_zlog_config[level]:-2}"
  local file_level="${_zlog_config[file_level]:--1}"
  (( file_level == -1 )) && file_level=$console_level

  if (( level_num > console_level && level_num > file_level )); then
    return 0
  fi

  __z::log::engine "$level_num" "$@"
}
