###
# Set maximum file size for rotation (in bytes)
# Usage: z::log::set_max_size 10485760  # 10MB
###
z::log::set_max_size() {
  emulate -L zsh
  local size="${1-}"

  __z::log::parse_size "$size"
  local parse_status=$?
  local size_bytes="$REPLY"

  if (( parse_status != 0 )) || [[ ! "$size_bytes" =~ '^[0-9]+$' ]] || (( size_bytes < 1 )); then
    print -r -u2 -- "zlog: Invalid max size: $size"
    return 1
  fi

  _zlog_config[rotate_size]=$size_bytes

  return 0
}

###
# Set number of rotated files to keep
# Usage: z::log::set_max_files 5
###
z::log::set_max_files() {
  emulate -L zsh
  local count="${1-}"

  # Validate it's a number
  if [[ ! "$count" =~ '^[0-9]+$' ]]; then
    print -r -u2 -- "zlog: Invalid max files: $count (must be a non-negative integer)"
    return 1
  fi

  _zlog_config[rotate_keep]=$count

  return 0
}

###
# Set buffer size (number of messages to buffer before writing)
# Only applies when buffering is enabled
# Usage: z::log::set_buffer_size 100
###
z::log::set_buffer_size() {
  emulate -L zsh
  local size="${1-}"

  if [[ ! "$size" =~ '^[0-9]+$' ]] || (( size < 1 )); then
    print -r -u2 -- "zlog: Invalid buffer size: $size (must be >= 1)"
    return 1
  fi

  _zlog_config[buffer_max]=$size

  return 0
}

